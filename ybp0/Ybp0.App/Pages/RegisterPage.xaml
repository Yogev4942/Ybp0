<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ybp0.App.Pages.RegisterPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource AppMint}">
    <ScrollView>
        <VerticalStackLayout Padding="24,36" Spacing="18">
            <Border Style="{StaticResource GlassCard}" MaximumWidthRequest="520">
                <VerticalStackLayout Spacing="16">
                    <Button Text="Back to login" Command="{Binding GoToLoginCommand}" Style="{StaticResource LinkButton}" HorizontalOptions="Start"/>
                    <Label Text="Create account" Style="{StaticResource DisplayTitle}"/>
                    <Label Text="Choose your role and fill in the details the API expects." Style="{StaticResource MutedText}"/>
                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource AppError}" FontSize="13"/>

                    <Border Style="{StaticResource InputShell}">
                        <Entry Placeholder="Username" Text="{Binding Username}"/>
                    </Border>
                    <Border Style="{StaticResource InputShell}">
                        <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email"/>
                    </Border>
                    <Border Style="{StaticResource InputShell}">
                        <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True"/>
                    </Border>
                    <Border Style="{StaticResource InputShell}">
                        <Picker ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}" Title="Role"/>
                    </Border>

                    <VerticalStackLayout Spacing="12" IsVisible="{Binding IsTrainee}">
                        <Border Style="{StaticResource InputShell}">
                            <Entry Placeholder="Fitness goal" Text="{Binding FitnessGoal}"/>
                        </Border>
                        <Grid ColumnDefinitions="*,12,*">
                            <Border Style="{StaticResource InputShell}">
                                <Entry Placeholder="Weight kg" Text="{Binding CurrentWeight}" Keyboard="Numeric"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource InputShell}">
                                <Entry Placeholder="Height cm" Text="{Binding Height}" Keyboard="Numeric"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="12" IsVisible="{Binding IsTrainer}">
                        <Border Style="{StaticResource InputShell}">
                            <Entry Placeholder="Specialization" Text="{Binding Specialization}"/>
                        </Border>
                        <Grid ColumnDefinitions="*,12,*">
                            <Border Style="{StaticResource InputShell}">
                                <Entry Placeholder="Hourly rate" Text="{Binding HourlyRate}" Keyboard="Numeric"/>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource InputShell}">
                                <Entry Placeholder="Max trainees" Text="{Binding MaxTrainees}" Keyboard="Numeric"/>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <Button Text="Create account" Command="{Binding RegisterCommand}" Style="{StaticResource PrimaryButton}"/>
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" Color="{StaticResource AppTeal}"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
