<Application x:Class="ybp0.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ybp0"
             xmlns:vm="clr-namespace:ViewModels.ViewModels;assembly=ViewModels"
             xmlns:views="clr-namespace:ybp0.Views"
             xmlns:converters="clr-namespace:ybp0.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter"/>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CalendarViewModel}">
            <views:CalendarView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TraineeCalendarViewModel}">
            <views:TraineeCalendarView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainerCalendarViewModel}">
            <views:TrainerCalendarView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
            <views:RegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TraineeRegisterViewModel}">
            <views:TraineeRegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainerRegisterViewModel}">
            <views:TrainerRegisterView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WorkoutViewModel}">
            <views:WorkoutView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ExerciseViewModel}">
            <views:ExerciseView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:FeedViewModel}">
            <views:FeedView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TraineeFeedViewModel}">
            <views:TraineeFeedView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainerFeedViewModel}">
            <views:TrainerFeedView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PostViewModel}">
            <views:PostView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <views:ProfileView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EditProfileViewModel}">
            <views:EditProfileView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TraineeProfileViewModel}">
            <views:TraineeProfileView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainerProfileViewModel}">
            <views:TrainerProfileView />
        </DataTemplate>
    </Application.Resources>
</Application>
