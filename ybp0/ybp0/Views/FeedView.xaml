<UserControl x:Class="ybp0.Views.FeedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E0F7FA" Offset="0.0" />
                <GradientStop Color="#80DEEA" Offset="0.5" />
                <GradientStop Color="#B2EBF2" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background Bubbles/Glows (Decorative) -->
        <Canvas>
            <Ellipse Width="300" Height="300" Fill="#40FFFFFF" Canvas.Left="-66" Canvas.Top="75">
                <Ellipse.Effect>
                    <BlurEffect Radius="70"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="200" Height="200" Fill="#3000E5FF" Canvas.Right="20" Canvas.Bottom="50">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title + Create Button -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Social Feed" 
                       FontSize="32" 
                       FontWeight="Bold" 
                       Foreground="#006064"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="White" BlurRadius="5" ShadowDepth="1" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Button HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Command="{Binding NavigateToCreatePostCommand}"
                        Cursor="Hand"
                        ToolTip="Create New Post">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="fabBorder"
                                    Width="48" Height="48" 
                                    CornerRadius="24"
                                    BorderBrush="#60FFFFFF" 
                                    BorderThickness="1.5">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#26A69A" Offset="0"/>
                                        <GradientStop Color="#00897B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect x:Name="fabGlow" 
                                                      Color="#26A69A" 
                                                      BlurRadius="8" 
                                                      ShadowDepth="2" 
                                                      Opacity="0.3"/>
                                </Border.Effect>
                                <TextBlock Text="+" 
                                           FontSize="28" 
                                           FontWeight="Bold" 
                                           Foreground="White" 
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Margin="0,-3,0,0"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="fabGlow"
                                                                 Storyboard.TargetProperty="BlurRadius"
                                                                 To="18" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="fabGlow"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.6" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="fabGlow"
                                                                 Storyboard.TargetProperty="BlurRadius"
                                                                 To="8" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="fabGlow"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.3" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="fabBorder" Property="Opacity" Value="0.85"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Posts List -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding Posts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <local:PostView />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
