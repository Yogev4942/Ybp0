<UserControl x:Class="ybp0.Views.TrainerFeedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E0F7FA" Offset="0.0" />
                <GradientStop Color="#80DEEA" Offset="0.5" />
                <GradientStop Color="#B2EBF2" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Background Bubbles/Glows (Decorative) -->
        <Canvas>
            <Ellipse Width="300" Height="300" Fill="#40FFFFFF" Canvas.Left="-50" Canvas.Top="-50">
                <Ellipse.Effect>
                    <BlurEffect Radius="60"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="200" Height="200" Fill="#3000E5FF" Canvas.Right="20" Canvas.Bottom="50">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title with Trainer Badge -->
            <StackPanel Orientation="Horizontal" Margin="10,0,0,20">
                <TextBlock Text="Social Feed" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="#006064">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="White" BlurRadius="5" ShadowDepth="1" Opacity="0.8"/>
                    </TextBlock.Effect>
                </TextBlock>
                <Border Background="#26A69A" 
                        CornerRadius="8" 
                        Padding="8,4" 
                        Margin="15,8,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="Moderator View" 
                               FontSize="12" 
                               FontWeight="SemiBold" 
                               Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- Posts List (Trainer view - with moderation controls) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden" PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding Posts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="10, 8">
                                <!-- Main Card Container -->
                                <Border CornerRadius="12"
                                        BorderThickness="1"
                                        BorderBrush="#40FFFFFF">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                            <GradientStop Color="#99F0F8FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#00B0FF" 
                                                          BlurRadius="15" 
                                                          ShadowDepth="2" 
                                                          Opacity="0.15"/>
                                    </Border.Effect>

                                    <Grid Margin="15">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/> <!-- Header -->
                                            <RowDefinition Height="*"/>    <!-- Content -->
                                            <RowDefinition Height="Auto"/> <!-- Footer -->
                                        </Grid.RowDefinitions>

                                        <!-- Header: Avatar + Name + Time + Moderation Controls -->
                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar (Clickable) -->
                                            <Button Command="{Binding NavigateToProfileCommand}"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    Padding="0"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Width="40" Height="40" CornerRadius="20" Background="{Binding AvatarColor, Converter={StaticResource StringToColorBrushConverter}}" 
                                                                BorderBrush="White" BorderThickness="2">
                                                            <Border.Effect>
                                                                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                            </Border.Effect>
                                                            <TextBlock Text="{Binding Initials}" 
                                                                       VerticalAlignment="Center" 
                                                                       HorizontalAlignment="Center" 
                                                                       Foreground="White" 
                                                                       FontWeight="Bold"
                                                                       FontSize="14"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>

                                            <!-- User Info -->
                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" 
                                                           FontWeight="Bold" 
                                                           FontSize="14" 
                                                           Foreground="#37474F"/>
                                                <TextBlock Text="{Binding Timestamp}" 
                                                           FontSize="11" 
                                                           Foreground="#78909C"/>
                                            </StackPanel>
                                            
                                            <!-- Moderation Controls (Trainer only) -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Pin Button -->
                                                <Button Content="📌" 
                                                        Cursor="Hand"
                                                        ToolTip="Pin Post"
                                                        Command="{Binding DataContext.PinPostCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="16"
                                                        Margin="0,0,8,0"/>
                                                
                                                <!-- Delete Button -->
                                                <Button Content="🗑️" 
                                                        Cursor="Hand"
                                                        ToolTip="Delete Post"
                                                        Command="{Binding DataContext.DeletePostCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#FFEBEE"
                                                        BorderThickness="0"
                                                        Foreground="#F44336"
                                                        FontSize="14"
                                                        Width="32"
                                                        Height="32">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="16"
                                                                    Padding="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Content -->
                                        <TextBlock Grid.Row="1" 
                                                   Text="{Binding Content}" 
                                                   TextWrapping="Wrap" 
                                                   FontSize="14" 
                                                   Foreground="#263238" 
                                                   LineHeight="20"
                                                   Margin="0,5,0,15"/>

                                        <!-- Footer: Actions -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                                            <!-- Like -->
                                            <Button Cursor="Hand"
                                                    Command="{Binding DataContext.LikePostCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border CornerRadius="12" Background="#2000B0FF" Padding="12,5" Margin="0,0,10,0">
                                                            <TextBlock Text="❤️ Like" Foreground="#0277BD" FontSize="12" FontWeight="SemiBold"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                            
                                            <!-- Comment -->
                                            <Border CornerRadius="12" Background="#10000000" Padding="12,5" Margin="0,0,10,0" Cursor="Hand">
                                                 <TextBlock Text="💬 Comment" Foreground="#546E7A" FontSize="12" FontWeight="SemiBold"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
