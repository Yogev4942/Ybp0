<UserControl x:Class="ybp0.Views.TrainerRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      HorizontalAlignment="Right"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Input Field Style -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#AAFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44009688"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#009688"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#AAFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44009688"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#009688"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00695C"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0"/>
                <GradientStop Color="#E0F2F1" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Glassy Register Card -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Padding="40" CornerRadius="22" Width="420" MaxHeight="700">
                <Border.Background>
                    <SolidColorBrush Color="#88FFFFFF"/>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#26A69A" BlurRadius="18" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="600"
                              Style="{StaticResource TransparentScrollViewer}">
                    <StackPanel>
                        <!-- Back Button -->
                        <Button Content="← Back"
                                Command="{Binding GoBackCommand}"
                                HorizontalAlignment="Left"
                                Height="32"
                                Padding="12,0"
                                FontSize="13"
                                Cursor="Hand"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderBrush="#44009688"
                                BorderThickness="1"
                                Foreground="#00695C">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"
                                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Title -->
                        <TextBlock Text="Create Trainer Account"
                                   Foreground="#004D40"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Share your expertise"
                                   Foreground="#00695C"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMsg}"
                                   Foreground="#D32F2F"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <!-- Email -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Username -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Username" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Password" Style="{StaticResource LabelStyle}"/>
                            <PasswordBox PasswordChanged="PasswordBox_PasswordChanged"
                                         Style="{StaticResource InputPasswordBoxStyle}"/>
                        </StackPanel>

                        <!-- Specialization -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Specialization" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Specialization, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Hourly Rate -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Hourly Rate (optional)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding HourlyRate, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Max Trainees -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Maximum Trainees (optional)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding MaxTrainees, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <!-- Register Button -->
                        <Button Content="Create Account"
                                Height="48"
                                Command="{Binding RegisterCommand}"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                BorderThickness="0"
                                Background="#26A69A"
                                Foreground="White">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
