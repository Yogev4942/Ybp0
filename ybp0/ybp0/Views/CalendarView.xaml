<UserControl x:Class="ybp0.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!-- Background matching main theme -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0.0" />
                <GradientStop Color="#E0F2F1" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Padding="30,25"
                Margin="20,20,20,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#26A69A" Offset="0"/>
                    <GradientStop Color="#00897B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="💪 Weekly Workout Plan" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Plan your training schedule" 
                           FontSize="14" 
                           Foreground="#DDFFFFFF" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Calendar Grid - Dynamic binding to Days collection -->
        <ItemsControl Grid.Row="1" 
                      ItemsSource="{Binding Days}" 
                      Margin="20,10,20,20">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="7"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <!-- Day Card with glassmorphism effect -->
                    <Border CornerRadius="16" 
                            Margin="6" 
                            Padding="12,15"
                            MinHeight="280">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#55FFFFFF" Offset="0"/>
                                <GradientStop Color="#33FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                        </Border.Effect>
                        
                        <StackPanel>
                            <!-- Day Name Header -->
                            <TextBlock Text="{Binding DayName}" 
                                       FontWeight="Bold" 
                                       FontSize="13"
                                       Foreground="#666" 
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,8"/>
                            
                            <!-- Workout Name Badge (for workout days) -->
                            <Border Background="{Binding AccentColor, Converter={StaticResource StringToColorBrushConverter}}" 
                                    CornerRadius="8" 
                                    Padding="8,5"
                                    Margin="0,0,0,10"
                                    Visibility="{Binding IsRestDay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <TextBlock Text="{Binding WorkoutName}" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White" 
                                           HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>
                            
                            <!-- Rest Day Badge -->
                            <Border Background="#FF6B6B" 
                                    CornerRadius="8" 
                                    Padding="8,5"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding IsRestDay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Rest Day" 
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White" 
                                           HorizontalAlignment="Center"/>
                            </Border>
                            
                            <!-- Rest Day Content -->
                            <TextBlock Text="Recovery &amp; Stretching" 
                                       FontSize="11"
                                       Foreground="#888" 
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"
                                       Visibility="{Binding IsRestDay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            
                            <!-- Exercises List with ExerciseView (for workout days) -->
                            <ScrollViewer MaxHeight="200" 
                                          VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding IsRestDay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding Exercises}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Embed the compact ExerciseView -->
                                            <local:ExerciseView DataContext="{Binding}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</UserControl>