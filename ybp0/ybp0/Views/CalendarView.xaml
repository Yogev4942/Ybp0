<UserControl x:Class="ybp0.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!-- Background matching main theme -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0.0" />
                <GradientStop Color="#E0F2F1" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Padding="30,25"
                Margin="20,20,20,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#26A69A" Offset="0"/>
                    <GradientStop Color="#00897B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            
            <StackPanel>
                <TextBlock Text="💪 Weekly Workout Plan" 
                           FontSize="32" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Plan your training schedule" 
                           FontSize="14" 
                           Foreground="#DDFFFFFF" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Calendar Grid -->
        <Grid Grid.Row="1" Margin="20,10,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sunday -->
            <Border Grid.Column="0" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#FF6B6B" BlurRadius="10" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="SUN" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#FF6B6B" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Rest Day" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Recovery &amp; Stretching" 
                              FontSize="11"
                              Foreground="#888" 
                              TextWrapping="Wrap"
                              HorizontalAlignment="Center"
                              TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Monday -->
            <Border Grid.Column="1" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="MON" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#26A69A" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Chest &amp; Triceps" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Bench Press&#x0a;• Dumbbell Flyes&#x0a;• Tricep Dips" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Tuesday -->
            <Border Grid.Column="2" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#66BB6A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="TUE" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#66BB6A" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Back &amp; Biceps" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Pull-ups&#x0a;• Barbell Rows&#x0a;• Bicep Curls" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Wednesday -->
            <Border Grid.Column="3" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#42A5F5" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="WED" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#42A5F5" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Legs" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Squats&#x0a;• Leg Press&#x0a;• Calf Raises" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Thursday -->
            <Border Grid.Column="4" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#AB47BC" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="THU" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#AB47BC" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Shoulders" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Overhead Press&#x0a;• Lateral Raises&#x0a;• Face Pulls" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Friday -->
            <Border Grid.Column="5" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#FF9800" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="FRI" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#FF9800" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Full Body" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Deadlifts&#x0a;• Push-ups&#x0a;• Planks" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>

            <!-- Saturday -->
            <Border Grid.Column="6" 
                    CornerRadius="16" 
                    Margin="6" 
                    Padding="15,20"
                    MinHeight="280">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#55FFFFFF" Offset="0"/>
                        <GradientStop Color="#33FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#7E57C2" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                </Border.Effect>
                
                <StackPanel>
                    <TextBlock Text="SAT" 
                              FontWeight="Bold" 
                              FontSize="13"
                              Foreground="#666" 
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>
                    <Border Background="#7E57C2" 
                           CornerRadius="8" 
                           Padding="8,5"
                           Margin="0,0,0,12">
                        <TextBlock Text="Cardio &amp; Core" 
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White" 
                                  HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="• Running&#x0a;• Ab Crunches&#x0a;• Leg Raises" 
                              FontSize="11"
                              Foreground="#666" 
                              TextWrapping="Wrap"
                              LineHeight="18"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>