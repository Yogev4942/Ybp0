<UserControl x:Class="ybp0.Views.CalendarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      HorizontalAlignment="Right"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <!-- Background matching main theme -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0.0" />
                <GradientStop Color="#E0F2F1" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <Border Grid.Row="0" 
                Padding="30,25"
                Margin="20,20,20,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#26A69A" Offset="0"/>
                    <GradientStop Color="#00897B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            
            <Grid>
                <StackPanel>
                    <TextBlock Text="💪 Weekly Workout Plan" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Plan your training schedule" 
                               FontSize="14" 
                               Foreground="#DDFFFFFF" 
                               HorizontalAlignment="Center"
                               Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Week Plan ID Indicator (Top Right) -->
                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top" Orientation="Horizontal">
                    <TextBlock Text="WeekPlan ID: " 
                               Foreground="#AAFFFFFF" 
                               FontSize="12" 
                               VerticalAlignment="Center"/>
                    <TextBox Text="{Binding DisplayWeekPlanId, UpdateSourceTrigger=PropertyChanged}" 
                             Foreground="White" 
                             Background="#22FFFFFF"
                             BorderThickness="0"
                             Padding="5,2"
                             FontSize="12"
                             Width="40"
                             TextAlignment="Center"
                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding WeekPlanOwnerLabel}" 
                               Foreground="#AAFFFFFF" 
                               FontSize="10" 
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               FontStyle="Italic"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Calendar Grid with Outer Scroll (7 columns, NO inner scrollers) -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      PanningMode="VerticalOnly" 
                      Margin="20,10,20,20"
                      Style="{StaticResource TransparentScrollViewer}">
            <ItemsControl ItemsSource="{Binding Days}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Day Card with glassmorphism effect -->
                        <Border CornerRadius="16" 
                                Margin="6" 
                                Padding="12,15">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>
                            
                            <StackPanel>
                                <!-- Day Name Header -->
                                <TextBlock Text="{Binding DayName}" 
                                           FontWeight="Bold" 
                                           FontSize="13"
                                           Foreground="#666" 
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                
                                <!-- Workout Name Badge (for workout days) -->
                                <Border Background="{Binding AccentColor, Converter={StaticResource StringToColorBrushConverter}}" 
                                        CornerRadius="8" 
                                        Padding="8,5"
                                        Margin="0,0,0,10"
                                        Visibility="{Binding IsRestDay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <TextBlock Text="{Binding WorkoutName}" 
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="White" 
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </Border>
                                
                                <!-- Rest Day Badge -->
                                <Border Background="#FF6B6B" 
                                        CornerRadius="8" 
                                        Padding="8,5"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding IsRestDay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Rest Day" 
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="White" 
                                               HorizontalAlignment="Center"/>
                                </Border>
                                
                                <!-- Rest Day Content -->
                                <TextBlock Text="Recovery &amp; Stretching" 
                                           FontSize="11"
                                           Foreground="#888" 
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Visibility="{Binding IsRestDay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                
                                <!-- Exercises List - NO SCROLLER, just StackPanel -->
                                <StackPanel Visibility="{Binding IsRestDay, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                    <ItemsControl ItemsSource="{Binding Exercises}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Embed the compact ExerciseView -->
                                                <local:ExerciseView DataContext="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Add Exercise Button (+) -->
                                    <Button Content="+"
                                            Command="{Binding DataContext.OpenExerciseModalCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            FontSize="18"
                                            FontWeight="Bold"
                                            Foreground="#26A69A"
                                            Background="Transparent"
                                            BorderThickness="1"
                                            BorderBrush="#26A69A"
                                            Margin="0,8,0,0"
                                            Padding="0,2"
                                            Cursor="Hand"
                                            ToolTip="Add an Exercise">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#26A69A"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>


        <!-- Global Exercise Modal Overlay -->
        <Grid Grid.RowSpan="2" 
              Visibility="{Binding IsExerciseModalOpen, Converter={StaticResource BoolToVisibilityConverter}}"
              Panel.ZIndex="1000">
            
            <!-- Dimmed Background (Click to close) -->
            <Border Background="#80000000" Cursor="Hand">
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding CloseExerciseModalCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Modal Content Card -->
            <Border Background="White" 
                    CornerRadius="16" 
                    Width="400" 
                    MaxHeight="600" 
                    Padding="0"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" 
                            Background="#26A69A" 
                            CornerRadius="16,16,0,0" 
                            Padding="20,15">
                        <Grid>
                            <TextBlock Text="Add Exercise" 
                                       FontSize="20" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>
                            
                            <Button HorizontalAlignment="Right"
                                    Content="✕"
                                    Command="{Binding CloseExerciseModalCommand}"
                                    Background="Transparent"
                                    Foreground="White"
                                    FontSize="16"
                                    BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Subheader / Target Day -->
                    <Border Grid.Row="1" Background="#F5F5F5" Padding="20,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Adding to: " Foreground="#666"/>
                            <TextBlock Text="{Binding SelectedDayForExercise.DayName}" 
                                       FontWeight="Bold" 
                                       Foreground="#26A69A"/>
                        </StackPanel>
                    </Border>

                    <!-- Exercise List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="10">
                        <ListBox ItemsSource="{Binding AllExercises}"
                                 SelectedItem="{Binding SelectedExercise}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="10"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="border" 
                                                        Background="White" 
                                                        CornerRadius="8" 
                                                        Padding="{TemplateBinding Padding}"
                                                        BorderThickness="1"
                                                        BorderBrush="#EEE">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Icon Placeholder -->
                                                        <Border Grid.Column="0" 
                                                                Width="40" Height="40" 
                                                                CornerRadius="20" 
                                                                Background="#E0F2F1"
                                                                Margin="0,0,15,0">
                                                            <TextBlock Text="🏋️" 
                                                                       HorizontalAlignment="Center" 
                                                                       VerticalAlignment="Center" 
                                                                       FontSize="20"/>
                                                        </Border>
                                                        
                                                        <!-- Text Info -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ExerciseName}" 
                                                                       FontWeight="SemiBold" 
                                                                       FontSize="15" 
                                                                       Foreground="#333"/>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="{Binding MuscleGroup}" 
                                                                           FontSize="12" 
                                                                           Foreground="#888"/>
                                                                <TextBlock Text=" | " 
                                                                           FontSize="12" 
                                                                           Foreground="#CCC"
                                                                           Visibility="{Binding SecondaryMuscleGroup, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding SecondaryMuscleGroup}" 
                                                                           FontSize="12" 
                                                                           Foreground="#888"
                                                                           FontStyle="Italic"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        
                                                        <!-- Arrow -->
                                                        <TextBlock Grid.Column="2" 
                                                                   Text="+" 
                                                                   FontSize="20" 
                                                                   Foreground="#26A69A" 
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="Bold"/>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#F0FDFC"/>
                                                        <Setter TargetName="border" Property="BorderBrush" Value="#26A69A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#26A69A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>
                    
                    <!-- Footer -->
                    <Border Grid.Row="3" Padding="20" BorderBrush="#EEE" BorderThickness="0,1,0,0">
                         <TextBlock Text="Select an exercise to add it instantly" 
                                    FontSize="11" 
                                    Foreground="#AAA" 
                                    HorizontalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>