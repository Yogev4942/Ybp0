<UserControl x:Class="ybp0.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Orientation="Vertical"
                                       HorizontalAlignment="Right"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Background matching main theme -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0.0"/>
                <GradientStop Color="#E0F2F1" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource TransparentScrollViewer}">
            <Grid MaxWidth="900" HorizontalAlignment="Center" Margin="30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Page Title -->
                <TextBlock Grid.Row="0" 
                           Text="🔍 Find a Trainer" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="#00695C"
                           Margin="0,0,0,20"/>

                <!-- Search Bar Card -->
                <Border Grid.Row="1" CornerRadius="16" Margin="0,0,0,25">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#26A69A" Offset="0"/>
                            <GradientStop Color="#00897B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>

                    <Grid Margin="20,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Search TextBox -->
                        <Border Grid.Column="0" Background="#44FFFFFF" CornerRadius="12" Padding="15,10" Margin="0,0,15,0">
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"
                                     FontSize="16"
                                     CaretBrush="White"
                                     VerticalAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>

                        <!-- Search Button -->
                        <Button Grid.Column="1"
                                Content="Search"
                                Command="{Binding SearchCommand}"
                                Cursor="Hand"
                                FontSize="16"
                                FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="searchBtn" Background="#22FFFFFF" CornerRadius="12" Padding="20,10"
                                            BorderBrush="#77FFFFFF" BorderThickness="1">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="searchBtn" Property="Background" Value="#44FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <Button.Foreground>
                                <SolidColorBrush Color="White"/>
                            </Button.Foreground>
                        </Button>
                    </Grid>
                </Border>

                <!-- Results Area -->
                <Grid Grid.Row="2">
                    <!-- No Results Message -->
                    <Border Visibility="{Binding HasSearched, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Margin="0,30,0,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasResults}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="No trainers found. Try a different search."
                                   FontSize="16"
                                   Foreground="#999"
                                   FontStyle="Italic"/>
                    </Border>

                    <!-- Trainer Cards -->
                    <ItemsControl ItemsSource="{Binding SearchResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Trainer Card -->
                                <Button Command="{Binding ViewProfileCommand}"
                                        Cursor="Hand"
                                        Margin="0,0,0,15">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="cardBorder" CornerRadius="16" Padding="20,18">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#CCFFFFFF" Offset="0"/>
                                                        <GradientStop Color="#99F0F8FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <DropShadowEffect x:Name="cardShadow" Color="#26A69A" BlurRadius="8" ShadowDepth="0" Opacity="0.15"/>
                                                </Border.Effect>
                                                <Border.BorderBrush>
                                                    <SolidColorBrush x:Name="cardBorderBrush" Color="#40FFFFFF"/>
                                                </Border.BorderBrush>
                                                <Border.BorderThickness>
                                                    <Thickness>1</Thickness>
                                                </Border.BorderThickness>

                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar -->
                                                    <Border Grid.Column="0" 
                                                            Width="56" Height="56" 
                                                            CornerRadius="28"
                                                            Background="{Binding AvatarColor, Converter={StaticResource StringToColorBrushConverter}}"
                                                            BorderBrush="White" BorderThickness="2.5"
                                                            VerticalAlignment="Center">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                                        </Border.Effect>
                                                        <TextBlock Text="{Binding Initials}"
                                                                   Foreground="White"
                                                                   FontWeight="Bold"
                                                                   FontSize="20"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" Margin="18,0,0,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Username}"
                                                                   FontSize="18"
                                                                   FontWeight="Bold"
                                                                   Foreground="#263238"/>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <Border Background="#E0F2F1" CornerRadius="8" Padding="8,3" Margin="0,0,8,0">
                                                                <TextBlock Text="{Binding Specialization}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#00695C"/>
                                                            </Border>
                                                            <Border Background="#FFF3E0" CornerRadius="8" Padding="8,3">
                                                                <TextBlock Text="{Binding RatingDisplay}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="#E65100"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                            <TextBlock Text="{Binding HourlyRateDisplay}"
                                                                       FontSize="13"
                                                                       Foreground="#78909C"
                                                                       Margin="0,0,15,0"/>
                                                            <TextBlock FontSize="13" Foreground="#78909C">
                                                                <Run Text="Trainees: "/>
                                                                <Run Text="{Binding TraineesDisplay, Mode=OneWay}"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <!-- Status + Arrow -->
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10,0,0,0">
                                                        <!-- Accepting Status -->
                                                        <Border CornerRadius="10" Padding="10,5" HorizontalAlignment="Right" Margin="0,0,0,8">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="#E8F5E9"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsAccepting}" Value="False">
                                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock FontSize="11" FontWeight="SemiBold">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="✅ Accepting"/>
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsAccepting}" Value="False">
                                                                                <Setter Property="Text" Value="⛔ Full"/>
                                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Border>
                                                        <!-- View Arrow -->
                                                        <TextBlock Text="→" 
                                                                   FontSize="20" 
                                                                   Foreground="#26A69A"
                                                                   FontWeight="Bold"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="cardBorder" Property="BorderBrush" Value="#26A69A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
