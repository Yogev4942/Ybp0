<UserControl x:Class="ybp0.Views.PostView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid Margin="10, 8">
        <!-- Main Card Container -->
        <Border CornerRadius="12"
                BorderThickness="1"
                BorderBrush="#40FFFFFF">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#CCFFFFFF" Offset="0"/>
                    <GradientStop Color="#99F0F8FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00B0FF" 
                                  BlurRadius="15" 
                                  ShadowDepth="2" 
                                  Opacity="0.15"/>
            </Border.Effect>

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Header -->
                    <RowDefinition Height="*"/>    <!-- Content -->
                    <RowDefinition Height="Auto"/> <!-- Footer -->
                </Grid.RowDefinitions>

                <!-- Header: Avatar + Name + Time + Delete Menu -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar (Clickable) -->
                    <Button Command="{Binding NavigateToProfileCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Width="60" Height="60" CornerRadius="30" Background="{Binding AvatarColor, Converter={StaticResource StringToColorBrushConverter}}" 
                                        BorderBrush="White" BorderThickness="2">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.2"/>
                                    </Border.Effect>
                                    <TextBlock Text="{Binding Initials}" 
                                               VerticalAlignment="Center" 
                                               HorizontalAlignment="Center" 
                                               Foreground="White" 
                                               FontWeight="Bold"
                                               FontSize="20"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- User Info -->
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Username}" 
                                   FontWeight="Bold" 
                                   FontSize="14" 
                                   Foreground="#37474F"/>
                        <TextBlock Text="{Binding Timestamp}" 
                                   FontSize="11" 
                                   Foreground="#78909C"/>
                    </StackPanel>
                    
                    <!-- Three Dots Menu -->
                    <Menu Grid.Column="2" Background="Transparent" VerticalAlignment="Center">
                         <MenuItem Header="..." FontSize="20" FontWeight="Bold" Foreground="#90A4AE" Background="Transparent" BorderThickness="0">
                             <MenuItem Header="Delete" 
                                       Command="{Binding DeleteCommand}"
                                       Visibility="{Binding CanDelete, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Foreground="Red"/>
                         </MenuItem>
                    </Menu>
                </Grid>

                <!-- Content -->
                <TextBlock Grid.Row="1" 
                           Text="{Binding Content}" 
                           TextWrapping="Wrap" 
                           FontSize="14" 
                           Foreground="#263238" 
                           LineHeight="20"
                           Margin="0,5,0,15"/>

                <!-- Footer: Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <!-- Like -->
                    <Button Cursor="Hand"
                            Command="{Binding ToggleLikeCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="likeBorder" CornerRadius="12" Background="#2000B0FF" Padding="12,5" Margin="0,0,10,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding LikeButtonText}" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding LikeCount}" Foreground="#0277BD" FontSize="12" FontWeight="SemiBold" 
                                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="likeBorder" Property="Background" Value="#3000B0FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
