<UserControl x:Class="ybp0.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="1"
                Width="350"
                Background="#1E1E1E"
                CornerRadius="20"
                Padding="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Effect="{DynamicResource ShadowEffect}">

            <StackPanel>
                <TextBlock Text="Welcome"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10" />

                <TextBlock Text="Sign up to continue"
                           Foreground="#888"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,25"/>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#FF6B6B"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Margin="0, -15, 0, 10" />

                <!-- Username/Email Input -->
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Username" Foreground="#aaa" FontSize="13" Margin="0,0,0,5"/>
                    <Border Background="#262626" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                        <TextBox Height="35"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 Padding="10"/>
                    </Border>
                </StackPanel>

                <!-- Password Input -->
                <StackPanel Margin="0,0,0,10">
                    <TextBlock Text="Password" Foreground="#aaa" FontSize="13" Margin="0,0,0,5"/>
                    <Border Background="#262626" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                        <TextBox Height="35"
                              Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                              Background="Transparent"
                              Foreground="White"
                              BorderThickness="0"
                              Padding="10"/>

                    </Border>
                </StackPanel>

                <!-- Forgot Password / Navigate to Sign Up -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,15">

                    <!-- Forgot Password -->
                    <Button Content="Forgot Password?"
            Command="{Binding ForgotPasswordCommand}"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#66CFFF"
            FontSize="12"
            FontWeight="SemiBold"
            Cursor="Hand"
            Padding="4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="#66CFFF"/>
                                <Setter Property="Opacity" Value="0.8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Sign Up -->
                    <Button Content="Register"
            Command="{Binding NavigateToSignUpCommand}"
            Background="Transparent"
            BorderThickness="0"
            Foreground="#A588FC"
            FontSize="12"
            FontWeight="Bold"
            Cursor="Hand"
            Padding="4">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Opacity" Value="0.8"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                </StackPanel>


                <!-- Login button -->
                <Button Content="Sign In"
                    Command="{Binding LoginCommand}"
                    Height="40"
                    Background="#a588fc"
                    Foreground="White"
                    FontWeight="SemiBold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,0,20">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>

                                <!-- Hover -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                </Trigger>

                                <!-- Pressed -->
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                    <Setter TargetName="border" Property="RenderTransform">
                                        <Setter.Value>
                                            <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>

                                <!-- Disabled -->
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                                </Trigger>

                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Social login -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <Rectangle Width="50" Height="1" Fill="#333"/>
                    <TextBlock Text="    Or Continue With:  " Foreground="#777" FontSize="12"/>
                    <Rectangle Width="50" Height="1" Fill="#333"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Width="40" Height="40" Background="#1877F2" BorderThickness="0" Margin="5,0" Style="{StaticResource {x:Type Button}}">
                        <TextBlock Text="f" FontSize="20" Foreground="White" FontWeight="Bold"/>
                    </Button>
                    <Button Width="40" Height="40" Background="#000000" BorderThickness="0" Margin="5,0" Style="{StaticResource {x:Type Button}}">
                        <TextBlock Text="" FontSize="18" Foreground="White"/>
                    </Button>
                    <Button Width="40" Height="40" Background="#DB4437" BorderThickness="0" Margin="5,0" Style="{StaticResource {x:Type Button}}">
                        <TextBlock Text="G" FontSize="18" Foreground="White"/>
                    </Button>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
