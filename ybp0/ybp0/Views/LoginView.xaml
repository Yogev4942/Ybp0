<UserControl x:Class="ybp0.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="Background" Value="#F6FFFFFF"/>
            <Setter Property="BorderBrush" Value="#44009688"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#009688"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00695C"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="LinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#00796B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#004D40"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HeroChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#18FFFFFF"/>
            <Setter Property="BorderBrush" Value="#3AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SocialButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EDF8F5" Offset="0"/>
                <GradientStop Color="#D9F1EC" Offset="0.55"/>
                <GradientStop Color="#E8F5E9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Ellipse Width="420"
                 Height="420"
                 Fill="#36FFFFFF"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-120,-110,0,0"/>
        <Ellipse Width="520"
                 Height="520"
                 Fill="#14FFFFFF"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-120,-160"/>

        <Grid Margin="48">
            <Border MaxWidth="1180"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    CornerRadius="30"
                    Background="#3AFFFFFF"
                    Padding="18">
                <Border.Effect>
                    <DropShadowEffect Color="#1A5B524D"
                                      BlurRadius="32"
                                      ShadowDepth="0"
                                      Opacity="0.22"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="430"/>
                        <ColumnDefinition Width="22"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            CornerRadius="24"
                            Background="#C8FFFFFF"
                            Padding="36,34">
                        <Border.Effect>
                            <DropShadowEffect Color="#2626A69A"
                                              BlurRadius="18"
                                              ShadowDepth="0"
                                              Opacity="0.18"/>
                        </Border.Effect>

                        <StackPanel>
                            <Border HorizontalAlignment="Left"
                                    Background="#15009688"
                                    BorderBrush="#24009688"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="10,5"
                                    Margin="0,0,0,16">
                                <TextBlock Text="YBP"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#00796B"/>
                            </Border>

                            <TextBlock Text="Welcome Back"
                                       Foreground="#004D40"
                                       FontSize="30"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>

                            <TextBlock Text="Sign in to continue building better performance."
                                       Foreground="#00695C"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,28"/>

                            <TextBlock Text="{Binding ErrorMessage}"
                                       Foreground="#D32F2F"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,14"/>

                            <StackPanel Margin="0,0,0,18">
                                <TextBlock Text="Username" Style="{StaticResource LabelStyle}"/>
                                <TextBox Height="46"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Password" Style="{StaticResource LabelStyle}"/>
                                <TextBox Height="46"
                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="0,0,0,20">
                                <Button Content="Forgot Password?"
                                        Command="{Binding ForgotPasswordCommand}"
                                        Style="{StaticResource LinkButtonStyle}"/>

                                <TextBlock Text=" | "
                                           Foreground="#00695C"
                                           VerticalAlignment="Center"
                                           Margin="6,0"/>

                                <Button Content="Register"
                                        Command="{Binding NavigateToSignUpCommand}"
                                        Style="{StaticResource LinkButtonStyle}"
                                        FontWeight="Bold"
                                        Foreground="#26A69A"/>
                            </StackPanel>

                            <Button Content="Sign In"
                                    Command="{Binding LoginCommand}"
                                    Height="48"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Cursor="Hand"
                                    Margin="0,0,0,22"
                                    BorderThickness="0"
                                    Foreground="White">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2BB7A4" Offset="0"/>
                                        <GradientStop Color="#168F7D" Offset="1"/>
                                    </LinearGradientBrush>
                                </Button.Background>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="12">
                                            <Border.Effect>
                                                <DropShadowEffect x:Name="glow"
                                                                  Color="#26A69A"
                                                                  BlurRadius="0"
                                                                  ShadowDepth="0"
                                                                  Opacity="0"/>
                                            </Border.Effect>
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                                             Storyboard.TargetProperty="BlurRadius"
                                                                             To="12"
                                                                             Duration="0:0:0.2"/>
                                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0.35"
                                                                             Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                                             Storyboard.TargetProperty="BlurRadius"
                                                                             To="0"
                                                                             Duration="0:0:0.2"/>
                                                            <DoubleAnimation Storyboard.TargetName="glow"
                                                                             Storyboard.TargetProperty="Opacity"
                                                                             To="0"
                                                                             Duration="0:0:0.2"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,18">
                                <Rectangle Width="68" Height="1" Fill="#3300695C"/>
                                <TextBlock Text="  or continue with  "
                                           Foreground="#00695C"
                                           FontSize="11"
                                           VerticalAlignment="Center"/>
                                <Rectangle Width="68" Height="1" Fill="#3300695C"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="#1877F2" Style="{StaticResource SocialButtonStyle}">
                                    <TextBlock Text="f"
                                               FontSize="22"
                                               Foreground="White"
                                               FontWeight="Bold"/>
                                </Button>
                                <Button Background="#111111" Style="{StaticResource SocialButtonStyle}">
                                    <TextBlock Text="A"
                                               FontSize="18"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Button>
                                <Button Background="#DB4437" Style="{StaticResource SocialButtonStyle}">
                                    <TextBlock Text="G"
                                               FontSize="20"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            CornerRadius="28"
                            Padding="34"
                            SnapsToDevicePixels="True">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0A6E62" Offset="0"/>
                                <GradientStop Color="#1A8A79" Offset="0.48"/>
                                <GradientStop Color="#2AAE9B" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border HorizontalAlignment="Left"
                                    Background="#1CFFFFFF"
                                    BorderBrush="#30FFFFFF"
                                    BorderThickness="1"
                                    CornerRadius="16"
                                    Padding="12,6">
                                <TextBlock Text="Built for progress"
                                           Foreground="White"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Border>

                            <Grid Grid.Row="1" Margin="0,26,0,26">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="0.9*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Top" Margin="0,8,24,0">
                                    <TextBlock Text="YBP"
                                               FontSize="74"
                                               FontWeight="Bold"
                                               Foreground="White"/>

                                    <TextBlock Text="Your Body's Performance"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="#E8FFFB"
                                               Margin="0,-8,0,10"/>

                                    <TextBlock Text="Plan your training, connect with trainers, and build real momentum with one focused fitness space."
                                               FontSize="16"
                                               Foreground="#E6FFFB"
                                               TextWrapping="Wrap"
                                               LineHeight="26"
                                               Margin="0,0,0,22"/>

                                    <Border Style="{StaticResource HeroChipStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Plan with purpose"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="Organize workouts, stay consistent, and keep your progress moving in the right direction."
                                                       Margin="0,4,0,0"
                                                       FontSize="13"
                                                       Foreground="#DFFAF4"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource HeroChipStyle}">
                                        <StackPanel>
                                            <TextBlock Text="Train with the right people"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="Find trainers, manage your fitness journey, and turn your routine into something more serious."
                                                       Margin="0,4,0,0"
                                                       FontSize="13"
                                                       Foreground="#DFFAF4"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <Grid Grid.Column="1" Margin="0,0,0,4">
                                    <Ellipse Width="250"
                                             Height="250"
                                             Fill="#14FFFFFF"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                    <Ellipse Width="320"
                                             Height="410"
                                             Stroke="#26FFFFFF"
                                             StrokeThickness="1.5"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>

                                    <Viewbox Stretch="Uniform" Margin="2,-8,6,0">
                                        <Image Source="pack://application:,,,/ybp0;component/images/ArnoldImage.png"
                                               Stretch="Uniform"/>
                                    </Viewbox>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
