<UserControl x:Class="ybp0.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="960"
             d:DesignHeight="640">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EFF8F5" Offset="0"/>
                <GradientStop Color="#DAEEE7" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">
                <Border Padding="28,24"
                        CornerRadius="26"
                        Margin="0,0,0,18">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1FAE9C" Offset="0"/>
                            <GradientStop Color="#0D8F81" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="18" ShadowDepth="0" Opacity="0.14"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding WelcomeMessage}"
                                       FontSize="31"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock Text="Your last month at a glance, with consistency blocks and strength progression."
                                       Margin="0,10,0,0"
                                       FontSize="14"
                                       Foreground="#D9FFFA"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#1DFFFFFF"
                                CornerRadius="20"
                                Padding="18,14"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Monthly Focus"
                                           FontSize="12"
                                           Foreground="#D7FFFA"/>
                                <TextBlock Text="{Binding MonthSummary}"
                                           Margin="0,6,0,0"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="0.85*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#FCFFFE"
                            CornerRadius="24"
                            Padding="22"
                            Margin="0,0,0,18">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07"/>
                        </Border.Effect>

                        <StackPanel>
                            <TextBlock Text="Exercise Blocks"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#163F38"/>
                            <TextBlock Text="A minimal 30-day streak board. Filled blocks mean you completed at least one workout that day."
                                       Margin="0,8,0,18"
                                       Foreground="#69827D"
                                       TextWrapping="Wrap"/>

                            <ItemsControl ItemsSource="{Binding ActivityDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding FillColor}"
                                                CornerRadius="16"
                                                Margin="6"
                                                Padding="10">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.04"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <TextBlock Text="{Binding WeekdayLabel}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           Foreground="#6C8480"/>
                                                <TextBlock Text="{Binding DayLabel}"
                                                           Margin="0,8,0,0"
                                                           FontSize="24"
                                                           FontWeight="Bold"
                                                           Foreground="#163F38"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <Border Background="#FCFFFE"
                                CornerRadius="24"
                                Padding="22"
                                Margin="0,0,0,18">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="Progress Metric"
                                           FontSize="22"
                                           FontWeight="Bold"
                                           Foreground="#163F38"/>
                                <TextBlock Text="{Binding StatisticsSummary}"
                                           Margin="0,8,0,0"
                                           Foreground="#69827D"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F4FBF8"
                                CornerRadius="24"
                                Padding="22">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>
                            </Border.Effect>

                            <StackPanel>
                                <TextBlock Text="How To Read It"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="#163F38"/>
                                <TextBlock Text="Each card below compares volume across recent completed sessions for the same exercise."
                                           Margin="0,8,0,12"
                                           Foreground="#69827D"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Higher bars mean more total work. This helps track progress even when sets and reps change between sessions."
                                           Foreground="#69827D"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="#FCFFFE"
                        CornerRadius="24"
                        Padding="22">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.07"/>
                    </Border.Effect>

                    <StackPanel>
                        <TextBlock Text="Exercise Progression"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#163F38"/>
                        <TextBlock Text="Recent volume history for the exercises you log most consistently."
                                   Margin="0,8,0,18"
                                   Foreground="#69827D"
                                   TextWrapping="Wrap"/>

                        <ItemsControl ItemsSource="{Binding ExerciseProgressCards}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F6FCFA"
                                            BorderBrush="#D9EBE5"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="18"
                                            Margin="0,0,0,14">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding ExerciseName}"
                                                               FontSize="18"
                                                               FontWeight="Bold"
                                                               Foreground="#163F38"/>
                                                    <TextBlock Text="{Binding Summary}"
                                                               Margin="0,6,0,0"
                                                               Foreground="#69827D"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        Background="{Binding AccentColor}"
                                                        CornerRadius="14"
                                                        Padding="12,8"
                                                        VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding LatestVolume, StringFormat=Latest {0:0}}"
                                                               FontWeight="SemiBold"
                                                               Foreground="White"/>
                                                </Border>
                                            </Grid>

                                            <ItemsControl ItemsSource="{Binding Points}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="80"/>
                                                                <ColumnDefinition Width="240"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Text="{Binding Label}"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#6B827D"/>

                                                            <Border Grid.Column="1"
                                                                    Height="18"
                                                                    Background="#E1F0EB"
                                                                    CornerRadius="9"
                                                                    VerticalAlignment="Center">
                                                                <Border Width="{Binding BarWidth}"
                                                                        HorizontalAlignment="Left"
                                                                        Background="#26A69A"
                                                                        CornerRadius="9"/>
                                                            </Border>

                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding VolumeLabel}"
                                                                       Margin="10,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="#163F38"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Complete at least two sessions for the same exercise to see a progression card."
                                   Foreground="#7A918C">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExerciseProgressCards.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
