<UserControl x:Class="ybp0.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="550">

    <!-- Simple, clean home view matching navigation aesthetic -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E3F2FD" Offset="0.0" />
                <GradientStop Color="#F1F8E9" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Welcome Section -->
        <StackPanel Grid.Row="0" Margin="40,30,40,20">
            <TextBlock Text="{Binding WelcomeMessage}"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="#00695C"/>
        </StackPanel>

        <!-- Main Content Card -->
        <Border Grid.Row="1"
                MaxWidth="700"
                MaxHeight="350"
                Margin="40"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                CornerRadius="24"
                Padding="45">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#55FFFFFF" Offset="0.0"/>
                    <GradientStop Color="#33FFFFFF" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#00FFCC"
                                 BlurRadius="20"
                                 ShadowDepth="0"
                                 Opacity="0.25"/>
            </Border.Effect>

            <Grid>
                <!-- Content -->
                <StackPanel HorizontalAlignment="Center"
                           VerticalAlignment="Center">
                    <TextBlock Text="Your Daily Focus"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#00897B"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Start your journey here"
                               FontSize="16"
                               Foreground="#26A69A"
                               HorizontalAlignment="Center"
                               Opacity="0.8"/>
                </StackPanel>

                <!-- Decorative glow -->
                <Ellipse Width="400" Height="400"
                        Fill="#1500FFCC"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False"
                        Opacity="0.15"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
