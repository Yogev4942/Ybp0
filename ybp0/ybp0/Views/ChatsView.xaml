<UserControl x:Class="ybp0.Views.ChatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <!-- Reuse same visual language -->
        <UserControl.Resources>

            <!-- Sidebar item -->
            <Style x:Key="ChatItemStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="12"/>
                <Setter Property="Margin" Value="0,4"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#25FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Message bubble -->
            <Style x:Key="MessageBubbleStyle" TargetType="Border">
                <Setter Property="Background" Value="#E0F2F1"/>
                <Setter Property="CornerRadius" Value="14"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Margin" Value="6"/>
                <Setter Property="MaxWidth" Value="400"/>
            </Style>

            <!-- Input box -->
            <Style x:Key="ChatInputStyle" TargetType="TextBox">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Padding" Value="10"/>
                <Setter Property="Background" Value="#F6FFFFFF"/>
                <Setter Property="BorderBrush" Value="#44009688"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

        </UserControl.Resources>

        <Grid>
            <!-- Background -->
            <Grid.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EDF8F5" Offset="0"/>
                    <GradientStop Color="#E8F5E9" Offset="1"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid Margin="30">
                <Border CornerRadius="20"
                    Background="#3AFFFFFF"
                    Padding="16">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Sidebar -->
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT SIDEBAR -->
                        <Border Background="#C8FFFFFF"
                            CornerRadius="16"
                            Padding="12"
                            Margin="0,0,12,0">

                            <StackPanel>
                                <TextBlock Text="Chats"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="#004D40"
                                       Margin="6,0,0,10"/>

                                <!-- Chat list -->
                                <ItemsControl ItemsSource="{Binding Chats}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource ChatItemStyle}"
                                                Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Avatar -->
                                                    <Ellipse Width="36"
                                                         Height="36"
                                                         Fill="#26A69A"
                                                         Margin="0,0,10,0"/>

                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="#004D40"/>
                                                        <TextBlock Text="{Binding LastMessage}"
                                                               FontSize="11"
                                                               Foreground="#00695C"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- RIGHT SIDE CHAT -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <!-- Header -->
                                <RowDefinition Height="60"/>
                                <!-- Messages -->
                                <RowDefinition Height="*"/>
                                <!-- Input -->
                                <RowDefinition Height="70"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Background="#C8FFFFFF"
                                CornerRadius="14"
                                Padding="12"
                                Margin="0,0,0,10">

                                <TextBlock Text="{Binding SelectedChat.Name}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#004D40"/>
                            </Border>

                            <!-- Messages -->
                            <ScrollViewer Grid.Row="1">
                                <ItemsControl ItemsSource="{Binding Messages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <Border Style="{StaticResource MessageBubbleStyle}">
                                                    <TextBlock Text="{Binding Text}"
                                                           TextWrapping="Wrap"
                                                           Foreground="#004D40"/>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Input -->
                            <Grid Grid.Row="2" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Text="{Binding NewMessage}"
                                     Style="{StaticResource ChatInputStyle}"
                                     Height="44"
                                     Margin="0,0,10,0"
                                     />

                                <Button Grid.Column="1"
                                    Content="Send"
                                    Command="{Binding SendMessageCommand}"
                                    Background="#26A69A"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Height="44">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                CornerRadius="10">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
</UserControl>
