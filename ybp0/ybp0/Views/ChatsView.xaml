<UserControl x:Class="ybp0.Views.ChatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             xmlns:converters="clr-namespace:ybp0.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
        <converters:BoolToBubbleCornerConverter x:Key="BoolToBubbleCornerConverter"/>
        <converters:StringToColorBrushConverter x:Key="StringToColorBrushConverter"/>

        <!-- Invisible scrollbar style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       Orientation="Vertical"
                                       HorizontalAlignment="Right"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Chat sidebar item button -->
        <Style x:Key="ChatItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#10009688"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#20009688"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Send button style -->
        <Style x:Key="SendButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="sendBd"
                                CornerRadius="14"
                                Padding="0"
                                Width="48" Height="48">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#26A69A" Offset="0"/>
                                    <GradientStop Color="#00897B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect x:Name="sendShadow" Color="#26A69A" BlurRadius="12" ShadowDepth="0" Opacity="0.35"/>
                            </Border.Effect>
                            <!-- Send arrow icon -->
                            <Canvas Width="22" Height="22" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Path Data="M2,12 L20,2 L14,12 L20,22 Z" 
                                      Fill="White" 
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0"/>
                                    </Path.RenderTransform>
                                </Path>
                            </Canvas>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sendShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="22" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="sendShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.6" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="sendShadow"
                                                           Storyboard.TargetProperty="BlurRadius"
                                                           To="12" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="sendShadow"
                                                           Storyboard.TargetProperty="Opacity"
                                                           To="0.35" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Outer background gradient -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF7F3" Offset="0"/>
                <GradientStop Color="#DFF3EE" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Margin="24,20">
            <Grid.ColumnDefinitions>
                <!-- Sidebar -->
                <ColumnDefinition Width="320"/>
                <!-- Chat area -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══════════════════════ LEFT SIDEBAR ══════════════════════ -->
            <Border CornerRadius="20" Margin="0,0,12,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F8FFFE" Offset="0"/>
                        <GradientStop Color="#EFF9F6" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#004D40" BlurRadius="20" ShadowDepth="0" Opacity="0.08"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header -->
                        <RowDefinition Height="Auto"/>
                        <!-- Chat list -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header -->
                    <Border Padding="20,20,20,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <!-- Chat icon -->
                                <TextBlock Text="💬" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Messages"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#004D40"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock FontSize="12"
                                       Foreground="#80004D40"
                                       Margin="38,0,0,0">
                                <Run Text="•"/>
                                <Run Text=" "/>
                                <Run Text="{Binding Chats.Count, FallbackValue=0, Mode=OneWay}"/>
                                <Run Text=" conversations"/>
                            </TextBlock>

                            <!-- Separator line -->
                            <Border Height="1" Margin="0,14,0,0" CornerRadius="1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00009688" Offset="0"/>
                                        <GradientStop Color="#30009688" Offset="0.5"/>
                                        <GradientStop Color="#00009688" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Chat List -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  Style="{StaticResource TransparentScrollViewer}"
                                  Padding="8,0,8,8">
                        <ItemsControl ItemsSource="{Binding Chats}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource ChatItemStyle}"
                                            Command="{Binding DataContext.SelectChatCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Avatar with colored ring -->
                                            <Border Width="46" Height="46"
                                                    CornerRadius="23"
                                                    Background="{Binding AvatarColor, Converter={StaticResource StringToColorBrushConverter}}"
                                                    BorderBrush="#20FFFFFF"
                                                    BorderThickness="2"
                                                    Margin="0,0,14,0">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="Black" BlurRadius="6" ShadowDepth="1" Opacity="0.12"/>
                                                </Border.Effect>
                                                <!-- User initial -->
                                                <TextBlock Text="{Binding Name[0]}"
                                                           Foreground="White"
                                                           FontWeight="Bold"
                                                           FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Name + last message -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1B3A34"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding LastMessage}"
                                                           FontSize="12"
                                                           Foreground="#80004D40"
                                                           Margin="0,3,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="18"/>
                                            </StackPanel>

                                            <!-- Online indicator dot -->
                                            <Ellipse Grid.Column="2"
                                                     Width="10" Height="10"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <RadialGradientBrush>
                                                        <GradientStop Color="#4CAF50" Offset="0"/>
                                                        <GradientStop Color="#2E7D32" Offset="1"/>
                                                    </RadialGradientBrush>
                                                </Ellipse.Fill>
                                                <Ellipse.Effect>
                                                    <DropShadowEffect Color="#4CAF50" BlurRadius="6" ShadowDepth="0" Opacity="0.5"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══════════════════════ RIGHT CHAT AREA ══════════════════════ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <!-- Header bar -->
                    <RowDefinition Height="Auto"/>
                    <!-- Messages -->
                    <RowDefinition Height="*"/>
                    <!-- Input bar -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ───── Chat Header ───── -->
                <Border CornerRadius="18" Margin="0,0,0,10" Padding="20,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F8FFFE" Offset="0"/>
                            <GradientStop Color="#EFF9F6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#004D40" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Selected user avatar -->
                        <Border Width="42" Height="42"
                                CornerRadius="21"
                                Background="{Binding SelectedChat.AvatarColor, Converter={StaticResource StringToColorBrushConverter}}"
                                Margin="0,0,14,0"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="5" ShadowDepth="1" Opacity="0.12"/>
                            </Border.Effect>
                            <TextBlock Text="{Binding SelectedChat.Name[0]}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="17"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Name and status -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedChat.Name}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#004D40"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#4CAF50" Offset="0"/>
                                            <GradientStop Color="#2E7D32" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Text="Online"
                                           FontSize="12"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Info / options icon -->
                        <Border Grid.Column="2"
                                Width="38" Height="38"
                                CornerRadius="19"
                                Background="#08004D40"
                                VerticalAlignment="Center">
                            <TextBlock Text="⋮"
                                       FontSize="20"
                                       Foreground="#004D40"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ───── Messages Area ───── -->
                <Border Grid.Row="1" CornerRadius="18" Margin="0,0,0,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FCFFFE" Offset="0"/>
                            <GradientStop Color="#F4FAF8" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#004D40" BlurRadius="14" ShadowDepth="0" Opacity="0.05"/>
                    </Border.Effect>

                    <Grid>
                        <!-- Empty state when no messages -->
                        <StackPanel VerticalAlignment="Center"
                                    HorizontalAlignment="Center">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="💬"
                                       FontSize="48"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"
                                       Opacity="0.4"/>
                            <TextBlock Text="No messages yet"
                                       FontSize="18"
                                       Foreground="#80004D40"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Send the first message to start the conversation!"
                                       FontSize="13"
                                       Foreground="#50004D40"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Messages list -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Style="{StaticResource TransparentScrollViewer}"
                                      Padding="20,16">
                            <ItemsControl ItemsSource="{Binding Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <!-- Message Bubble -->
                                            <Border MaxWidth="460"
                                                    Padding="14,10,14,8"
                                                    CornerRadius="{Binding IsSentByMe, Converter={StaticResource BoolToBubbleCornerConverter}}"
                                                    HorizontalAlignment="{Binding IsSentByMe, Converter={StaticResource BoolToAlignmentConverter}}">
                                                <!-- Sent messages = teal gradient, Received = light glass -->
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background">
                                                            <Setter.Value>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                    <GradientStop Color="#E8F5F2" Offset="0"/>
                                                                    <GradientStop Color="#E0F0EC" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSentByMe}" Value="True">
                                                                <Setter Property="Background">
                                                                    <Setter.Value>
                                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                            <GradientStop Color="#26A69A" Offset="0"/>
                                                                            <GradientStop Color="#00897B" Offset="1"/>
                                                                        </LinearGradientBrush>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.Effect>
                                                    <DropShadowEffect Color="#004D40" BlurRadius="8" ShadowDepth="2" Opacity="0.06"/>
                                                </Border.Effect>

                                                <StackPanel>
                                                    <!-- Message text -->
                                                    <TextBlock Text="{Binding Text}"
                                                               TextWrapping="Wrap"
                                                               FontSize="14"
                                                               LineHeight="20">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#1B3A34"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSentByMe}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Timestamp -->
                                                    <TextBlock Text="{Binding FormattedTime}"
                                                               FontSize="10"
                                                               Margin="0,4,0,0"
                                                               HorizontalAlignment="Right">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#60004D40"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSentByMe}" Value="True">
                                                                        <Setter Property="Foreground" Value="#99FFFFFF"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ───── Input Bar ───── -->
                <Border Grid.Row="2" CornerRadius="18" Padding="14,10">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F8FFFE" Offset="0"/>
                            <GradientStop Color="#EFF9F6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#004D40" BlurRadius="16" ShadowDepth="0" Opacity="0.06"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <!-- Emoji button -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Input field -->
                            <ColumnDefinition Width="*"/>
                            <!-- Send button -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Emoji / attach icon button -->
                        <Border Width="40" Height="40"
                                CornerRadius="20"
                                Background="#08004D40"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                            <TextBlock Text="😊"
                                       FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Message input -->
                        <Border Grid.Column="1" 
                                Background="#08004D40"
                                CornerRadius="14"
                                Padding="16,0"
                                Margin="0,0,12,0">
                            <TextBox Text="{Binding NewMessage, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     FontSize="14"
                                     Foreground="#1B3A34"
                                     CaretBrush="#26A69A"
                                     VerticalAlignment="Center"
                                     Height="44"
                                     VerticalContentAlignment="Center">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Return" Command="{Binding SendMessageCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </Border>

                        <!-- Send Button -->
                        <Button Grid.Column="2"
                                Command="{Binding SendMessageCommand}"
                                Style="{StaticResource SendButtonStyle}"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
