<UserControl x:Class="ybp0.Views.EditProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Input Field Style -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#AAFFFFFF"/>
            <Setter Property="BorderBrush" Value="#44009688"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#009688"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Label Style -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00695C"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0"/>
                <GradientStop Color="#E0F2F1" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Disabled">
            <Border MaxWidth="600" Margin="30" Background="#88FFFFFF" CornerRadius="20" Padding="30">
                <Border.Effect>
                    <DropShadowEffect Color="#26A69A" BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
                </Border.Effect>
                
                <StackPanel>
                    <!-- Header -->
                    <TextBlock Text="✏️ Edit Profile" FontSize="28" FontWeight="Bold" Foreground="#004D40" Margin="0,0,0,25" HorizontalAlignment="Center"/>

                    <!-- Common Fields -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Email" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Email}" Style="{StaticResource InputTextBoxStyle}"/>
                    </StackPanel>

                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Bio" Style="{StaticResource LabelStyle}"/>
                        <TextBox Text="{Binding Bio}" 
                                 Style="{StaticResource InputTextBoxStyle}" 
                                 Height="80" 
                                 TextWrapping="Wrap" 
                                 VerticalContentAlignment="Top"
                                 AcceptsReturn="True"/>
                    </StackPanel>

                    <!-- Trainee Specific Fields -->
                    <StackPanel Visibility="{Binding IsTrainee, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Fitness Goal" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding FitnessGoal}" Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Current Weight (kg)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding CurrentWeight}" Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Height (cm)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding Height}" Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Trainer Specific Fields -->
                    <StackPanel Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Specialization" Style="{StaticResource LabelStyle}"/>
                            <TextBox Text="{Binding Specialization}" Style="{StaticResource InputTextBoxStyle}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Hourly Rate ($)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding HourlyRate}" Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Max Trainees" Style="{StaticResource LabelStyle}"/>
                                <TextBox Text="{Binding MaxTrainees}" Style="{StaticResource InputTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Action Buttons -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" Content="Cancel" Command="{Binding CancelCommand}"
                                FontSize="16" FontWeight="SemiBold" Background="#FFEBEE" Foreground="#D32F2F"
                                BorderThickness="0" Padding="15" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="2" Content="Save Changes" Command="{Binding SaveCommand}"
                                FontSize="16" FontWeight="SemiBold" Background="#26A69A" Foreground="White"
                                BorderThickness="0" Padding="15" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>
