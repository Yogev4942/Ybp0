<UserControl x:Class="ybp0.Views.EditProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Background" Value="#F5F9F8"/>
            <Setter Property="BorderBrush" Value="#CFD8DC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#26A69A"/>
                                <Setter Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00796B"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontSize="18" FontWeight="SemiBold" Margin="20,10"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" BorderThickness="0,0,0,3" BorderBrush="Transparent" Margin="0,0,15,5">
                            <ContentPresenter ContentSource="Header" x:Name="content"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#26A69A"/>
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="#00695C"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="content" Property="TextBlock.Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#26A69A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="26,14"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#1A004D40" BlurRadius="10" ShadowDepth="2" Opacity="0.18"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00897B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" BorderBrush="#DDD" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAF9">
        <Ellipse Width="400" Height="400" Fill="#1026A69A" Margin="-200,-200,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Ellipse Width="300" Height="300" Fill="#0826A69A" Margin="0,0,-150,-150" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

        <Grid MaxWidth="1280" HorizontalAlignment="Stretch" Margin="48,40,48,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,40">
                <TextBlock Text="Profile Settings" FontSize="42" FontWeight="Bold" Foreground="#004D40"/>
                <TextBlock Text="Manage your public identity and account details." FontSize="16" Foreground="#666" Margin="0,5,0,0"/>
            </StackPanel>

            <TabControl Grid.Row="1"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch">
                <TabItem Header="Public Profile">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,20,0,0">
                        <Grid HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.15*"/>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="0.95*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="White" CornerRadius="20" Padding="32" Margin="0,0,0,25">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.05" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="About Me" Style="{StaticResource LabelStyle}" FontSize="18" Margin="0,0,0,20"/>
                                        <TextBox Text="{Binding Bio}"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 MinHeight="300"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalContentAlignment="Top"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Background="White"
                                        CornerRadius="20"
                                        Padding="32"
                                        Margin="0,0,0,25"
                                        Visibility="{Binding IsTrainee, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.05" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Fitness Snapshot" Style="{StaticResource LabelStyle}" FontSize="18" Margin="0,0,0,20"/>

                                        <TextBlock Text="Main Goal" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding FitnessGoal}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Weight (kg)" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding CurrentWeight}" Style="{StaticResource InputTextBoxStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Height (cm)" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding Height}" Style="{StaticResource InputTextBoxStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="White"
                                        CornerRadius="20"
                                        Padding="32"
                                        Margin="0,0,0,25"
                                        Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.05" ShadowDepth="2"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Coaching Details" Style="{StaticResource LabelStyle}" FontSize="18" Margin="0,0,0,20"/>

                                        <TextBlock Text="Specialization" Style="{StaticResource LabelStyle}"/>
                                        <TextBox Text="{Binding Specialization}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Hourly Rate ($)" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding HourlyRate}" Style="{StaticResource InputTextBoxStyle}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="Max Trainees" Style="{StaticResource LabelStyle}"/>
                                                <TextBox Text="{Binding MaxTrainees}" Style="{StaticResource InputTextBoxStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Button Content="Save Profile Changes"
                                        Command="{Binding SaveCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Stretch"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Account Info">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,20,0,0">
                        <Grid HorizontalAlignment="Stretch">
                            <Border Background="White"
                                    CornerRadius="20"
                                    Padding="36"
                                    Margin="0,0,0,25"
                                    MaxWidth="900"
                                    HorizontalAlignment="Center">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="20" Opacity="0.05" ShadowDepth="2"/>
                                </Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="Account Credentials" Style="{StaticResource LabelStyle}" FontSize="18" Margin="0,0,0,20"/>

                                    <TextBlock Text="Username" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Username}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,20"/>

                                    <TextBlock Text="Email Address" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Text="{Binding Email}" Style="{StaticResource InputTextBoxStyle}" Margin="0,0,0,10"/>

                                    <TextBlock Text="Your email and username are used for login and identification."
                                               FontSize="12"
                                               Foreground="#888"
                                               Margin="0,0,0,30"/>

                                    <Button Content="Update Account Details"
                                            Command="{Binding SaveAccountCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <Grid Grid.Row="2" Margin="0,30,0,0">
                <Button Content="Back to Profile"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Left"
                        Padding="20,10"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
