<UserControl x:Class="ybp0.Views.TraineeProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44FFFFFF" Offset="0"/>
                        <GradientStop Color="#22FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#77FFFFFF"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}" 
                        CornerRadius="15">
                            <Border.Effect>
                                <DropShadowEffect x:Name="shadow" Color="#00FFCC" BlurRadius="5" ShadowDepth="0" Opacity="0.2"/>
                            </Border.Effect>
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}">
                                    <ContentPresenter.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="3" ShadowDepth="1" Opacity="0.5"/>
                                    </ContentPresenter.Effect>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" 
                                                  Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].Color"
                                                  To="#66FFFFFF" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                   Storyboard.TargetProperty="BlurRadius"
                                                   To="20" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.9" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                  Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].Color"
                                                  To="#44FFFFFF" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                   Storyboard.TargetProperty="BlurRadius"
                                                   To="5" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="shadow"
                                                   Storyboard.TargetProperty="Opacity"
                                                   To="0.2" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      HorizontalAlignment="Right"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Background matching main theme -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E8F5E9" Offset="0.0"/>
                <GradientStop Color="#E0F2F1" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource TransparentScrollViewer}">
            <Grid MaxWidth="1600" HorizontalAlignment="Stretch" Margin="30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header Card with Avatar and Basic Info -->
                <Border Grid.Row="0" 
                        CornerRadius="20" 
                        Margin="0,0,0,20">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#26A69A" Offset="0"/>
                            <GradientStop Color="#00897B" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#00FFCC" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>
                    </Border.Effect>

                    <Grid Margin="20,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35*"/>
                            <RowDefinition Height="9*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Large Avatar Circle -->
                        <Border Grid.Column="0" 
                                Width="120" 
                                Height="120" 
                                CornerRadius="60" 
                                Background="{Binding AvatarColor, Converter={StaticResource StringToColorBrushConverter}}" 
                                BorderBrush="White" 
                                BorderThickness="4"
                                VerticalAlignment="Top" Grid.RowSpan="2">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                            </Border.Effect>
                            <TextBlock Text="{Binding Initials}" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="48"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- User Info Section -->
                        <StackPanel Grid.Column="1" Margin="30,0,0,0" VerticalAlignment="Top" Grid.RowSpan="2">
                            <!-- Username -->
                            <TextBlock Text="{Binding Username}" 
                                       FontSize="32" 
                                       FontWeight="Bold" 
                                       Foreground="White"/>

                            <!-- User Type Badge -->
                            <Border Background="#22FFFFFF" 
                                    CornerRadius="12" 
                                    Padding="12,6" 
                                    HorizontalAlignment="Left"
                                    Margin="0,8,0,0">
                                <TextBlock Text="{Binding UserTypeLabel}" 
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>

                            <!-- Join Date -->
                            <TextBlock Text="{Binding JoinDateText}" 
                                       FontSize="13" 
                                       Foreground="#DDFFFFFF" 
                                       Margin="0,12,0,0"/>

                            <!-- Email -->
                            <TextBlock Text="{Binding Email}" 
                                       FontSize="13" 
                                       Foreground="#DDFFFFFF" 
                                       Margin="0,4,0,0"/>

                            <!-- Actions / Request Status (Trainee viewing a Trainer profile) -->
                            <StackPanel Margin="0,20,0,0">
                                <!-- Request Trainer Button -->
                                <Button Content="➕ Request Trainer" 
                                        Style="{DynamicResource NavButtonStyle}"
                                        HorizontalAlignment="Left"
                                        Margin="0"
                                        Padding="15,8"
                                        FontSize="14"
                                        Visibility="{Binding CanRequestTrainer, Converter={StaticResource BoolToVisibilityConverter}}"
                                        Command="{Binding RequestTrainerCommand}"/>

                                <!-- Pending Label -->
                                <Border Background="#FFEB3B" 
                                        CornerRadius="12" 
                                        Padding="12,6" 
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding IsRequestPending, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳ Request Pending" 
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#333"/>
                                    </StackPanel>
                                </Border>

                                <!-- Approved Label -->
                                <Border Background="#4CAF50" 
                                        CornerRadius="12" 
                                        Padding="12,6" 
                                        HorizontalAlignment="Left"
                                        Visibility="{Binding IsRequestApproved, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✅ Your Trainer" 
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <!-- Edit Profile Button (Top Right) -->
                        <Button Grid.Column="1"
                                Content="✏️ Edit" 
                                Command="{Binding EditProfileCommand}"
                                Visibility="{Binding IsOwnProfile, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,20,20,0"
                                Background="#33FFFFFF"
                                BorderThickness="0"
                                Foreground="White"
                                Padding="15,8"
                                FontSize="14"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Main Content Grid -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0">

                        <!-- Bio Card -->
                        <Border CornerRadius="16" Margin="0,0,0,25">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel Margin="30,25">
                                <TextBlock Text="📝 Bio" 
                                           FontSize="20" 
                                           FontWeight="SemiBold" 
                                           Foreground="#00695C"
                                           Margin="0,0,0,15"/>
                                <TextBlock Text="{Binding Bio}" 
                                           FontSize="16" 
                                           Foreground="#555" 
                                           TextWrapping="Wrap"
                                           LineHeight="24"
                                           MinHeight="80"/>
                            </StackPanel>
                        </Border>

                        <!-- Fitness Stats Card -->
                        <Border CornerRadius="16" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel Margin="30,25">
                                <TextBlock Text="💪 Fitness Stats" 
                                           FontSize="20" 
                                           FontWeight="SemiBold" 
                                           Foreground="#00695C"
                                           Margin="0,0,0,18"/>

                                <!-- Current Weight -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Current Weight" 
                                               FontSize="15" 
                                               Foreground="#666"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding CurrentWeightDisplay}" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               Foreground="#26A69A"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Height -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Height" 
                                               FontSize="15" 
                                               Foreground="#666"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding HeightDisplay}" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               Foreground="#26A69A"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- BMI Calculation -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="BMI" 
                                               FontSize="15" 
                                               Foreground="#666"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding BMI}" 
                                               FontSize="18" 
                                               FontWeight="Bold" 
                                               Foreground="#26A69A"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="2">

                        <!-- Fitness Goal Card -->
                        <Border CornerRadius="16" Margin="0,0,0,20">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel Margin="30,25">
                                <TextBlock Text="🎯 Fitness Goal" 
                                           FontSize="20" 
                                           FontWeight="SemiBold" 
                                           Foreground="#00695C"
                                           Margin="0,0,0,15"/>
                                <TextBlock Text="{Binding FitnessGoal}" 
                                           FontSize="16" 
                                           Foreground="#555" 
                                           TextWrapping="Wrap"
                                           LineHeight="24"/>
                            </StackPanel>
                        </Border>

                        <!-- Personal Info Card -->
                        <Border CornerRadius="16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                    <GradientStop Color="#33FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#26A69A" BlurRadius="10" ShadowDepth="0" Opacity="0.25"/>
                            </Border.Effect>

                            <StackPanel Margin="30,25">
                                <TextBlock Text="👤 Personal Info" 
                                           FontSize="20" 
                                           FontWeight="SemiBold" 
                                           Foreground="#00695C"
                                           Margin="0,0,0,18"/>

                                <!-- Gender -->
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Gender" 
                                               FontSize="15" 
                                               Foreground="#666"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" 
                                               Text="{Binding Gender}" 
                                               FontSize="15" 
                                               Foreground="#333"
                                               VerticalAlignment="Center"/>
                                </Grid>

                                <!-- Account Type -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Account Type" 
                                               FontSize="15" 
                                               Foreground="#666"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" 
                                            Background="#E0F2F1" 
                                            CornerRadius="8" 
                                            Padding="8,4">
                                        <TextBlock Text="{Binding UserTypeLabel}" 
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#00695C"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
