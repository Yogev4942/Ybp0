<UserControl x:Class="ybp0.Views.TraineeRegisterView_Dark"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      HorizontalAlignment="Right"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Opacity="0"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#004D40" Offset="0"/>
                <GradientStop Color="#00897B" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Glassy Register Card -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border Padding="40" CornerRadius="22" Width="420" MaxHeight="700">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44FFFFFF" Offset="0"/>
                        <GradientStop Color="#22FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect Color="#69F0AE" BlurRadius="18" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>

                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="600"
                              Style="{StaticResource TransparentScrollViewer}">
                    <StackPanel>
                        <!-- Back Button -->
                        <Button Content="← Back"
                                Command="{Binding GoBackCommand}"
                                HorizontalAlignment="Left"
                                Height="32"
                                Padding="12,0"
                                FontSize="13"
                                Cursor="Hand"
                                Margin="0,0,0,15"
                                Background="Transparent"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                Foreground="#AAFFFFFF">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="10"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"
                                                          TextBlock.Foreground="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Title -->
                        <TextBlock Text="Create Trainee Account"
                                   Foreground="White"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="Start your fitness journey"
                                   Foreground="#DDFFFFFF"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMsg}"
                                   Foreground="Red"
                                   FontSize="14"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>

                        <!-- Email -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Email" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Username -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Username" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Password -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Password" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Fitness Goal -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Fitness Goal" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding FitnessGoal, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Current Weight -->
                        <StackPanel Margin="0,0,0,15">
                            <TextBlock Text="Current Weight (kg)" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding CurrentWeight, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Height -->
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="Height (cm)" 
                                       Foreground="#DDFFFFFF" 
                                       FontSize="13" 
                                       Margin="0,0,0,6"/>
                            <Border CornerRadius="12" Background="#33FFFFFF" BorderBrush="#55FFFFFF" BorderThickness="1" Padding="12">
                                <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="White"
                                         Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <!-- Register Button -->
                        <Button Content="Create Account"
                                Height="48"
                                Command="{Binding RegisterCommand}"
                                FontSize="16"
                                FontWeight="Bold"
                                Cursor="Hand"
                                BorderThickness="0"
                                Foreground="White">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#69F0AE" Offset="0"/>
                                    <GradientStop Color="#26A69A" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
