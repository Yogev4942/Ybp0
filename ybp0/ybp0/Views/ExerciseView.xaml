<UserControl x:Class="ybp0.Views.ExerciseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="300">
    <!-- This Border gives the "Round Palette" look -->
    <Border Background="#2D2D30" 
            CornerRadius="15" 
            Padding="15"
            Margin="5">
        <Border.Effect>
            <!-- Adds a slight shadow for depth -->
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Exercise Name -->
                <RowDefinition Height="Auto"/>
                <!-- Column Headers -->
                <RowDefinition Height="*"/>
                <!-- List of Sets -->
                <RowDefinition Height="Auto"/>
                <!-- Add Button -->
            </Grid.RowDefinitions>

            <!-- 1. Exercise Name -->
            <TextBlock x:Name="TxtExerciseName" 
                       Text="Bench Press" 
                       Foreground="White" 
                       FontSize="18" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10"
                       HorizontalAlignment="Left"/>

            <!-- 2. Column Headers (Reps / Weight) -->
            <Grid Grid.Row="1" Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="30"/>
                    <!-- Set # -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Delete Btn Space -->
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="#" Foreground="#AAAAAA" FontSize="12"/>
                <TextBlock Grid.Column="1" Text="Reps" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="Kg/Lbs" Foreground="#AAAAAA" FontSize="12" HorizontalAlignment="Center"/>
            </Grid>

            <!-- 3. Dynamic List of Sets -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SetsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Set Number -->
                                <TextBlock Text="{Binding SetNumber}" 
                                           Foreground="White" 
                                           VerticalAlignment="Center" 
                                           FontWeight="Bold"/>

                                <!-- Reps Input -->
                                <TextBox Text="{Binding Reps}" 
                                         Grid.Column="1"
                                         Margin="4,0"
                                         Padding="5"
                                         Background="#404040"
                                         Foreground="White"
                                         BorderThickness="0"
                                         HorizontalContentAlignment="Center"/>

                                <!-- Weight Input -->
                                <TextBox Text="{Binding Weight}" 
                                         Grid.Column="2"
                                         Margin="4,0"
                                         Padding="5"
                                         Background="#404040"
                                         Foreground="White"
                                         BorderThickness="0"
                                         HorizontalContentAlignment="Center"/>

                                <!-- Delete Set Button (Optional) -->
                                <Button Content="X" 
                                        Grid.Column="3"
                                        Width="20" Height="20"
                                        FontSize="10"
                                        Background="Transparent"
                                        Foreground="Red"
                                        BorderThickness="0"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 4. Add Set Button -->
            <Button Grid.Row="3" 
                    Content="+ Add Set" 
                    Background="#3A3A3E"
                    Foreground="White"
                    BorderThickness="0"
                    Height="30"
                    Margin="0,10,0,0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Border>

</UserControl>
