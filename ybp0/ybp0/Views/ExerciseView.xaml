<UserControl x:Class="ybp0.Views.ExerciseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             x:Name="uc"
             d:DesignHeight="60" d:DesignWidth="200">
    
    <!-- Compact Exercise View - fits inside day cards -->
    <Border CornerRadius="6" 
            Padding="8,6"
            Margin="0,3">
        <Border.Background>
            <SolidColorBrush Color="White" Opacity="0.5"/>
        </Border.Background>
        
        <StackPanel>
            <!-- Exercise Name Row with Remove Button -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Exercise Name -->
                <TextBlock Grid.Column="0"
                           Text="{Binding ExerciseName}" 
                           FontSize="11" 
                           FontWeight="SemiBold" 
                           Foreground="#333"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                
                <!-- Tiny X Remove Button -->
                <Button Grid.Column="1"
                        Content="✕"
                        FontSize="9"
                        Foreground="#AAA"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="3,1"
                        Cursor="Hand"
                        ToolTip="Remove Exercise"
                        Command="{Binding RemoveExerciseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FFEBEE"/>
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            
            <!-- Sets List - Compact inline -->
            <ItemsControl ItemsSource="{Binding Sets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Set Number -->
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding SetNumber, StringFormat='#{0}'}"
                                       FontSize="9"
                                       Foreground="#888"
                                       VerticalAlignment="Center"
                                       Width="16"/>
                            
                            <!-- Reps -->
                            <Border Grid.Column="1" Background="#F5F5F5" CornerRadius="3" Margin="2,0" Padding="4,2">
                                <TextBox Text="{Binding Reps, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="10"
                                         Foreground="#333"
                                         TextAlignment="Center"
                                         VerticalAlignment="Center"
                                         ToolTip="Reps"/>
                            </Border>
                            
                            <!-- Weight -->
                            <Border Grid.Column="2" Background="#F5F5F5" CornerRadius="3" Margin="2,0" Padding="4,2">
                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="10"
                                         Foreground="#333"
                                         TextAlignment="Center"
                                         VerticalAlignment="Center"
                                         ToolTip="kg"/>
                            </Border>
                            
                            <!-- Remove Set -->
                            <Button Grid.Column="3"
                                    Content="×"
                                    FontSize="10"
                                    Foreground="#CCC"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="2,0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.RemoveSetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <!-- Add Set Button - Small + -->
            <Button Content="+"
                    Command="{Binding AddSetCommand}"
                    FontSize="10"
                    FontWeight="Bold"
                    Foreground="#26A69A"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,2"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    ToolTip="Add Set">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#E0F2F1" CornerRadius="3" Padding="6,2">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#B2DFDB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
