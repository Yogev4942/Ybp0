<UserControl x:Class="ybp0.Views.ExerciseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d"
             x:Name="uc"
             d:DesignHeight="80" d:DesignWidth="300">

    <Border CornerRadius="8"
            Padding="12,8"
            Margin="0,4"
            Background="#F5F5F5">

        <StackPanel>
            <Grid Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding ExerciseName}"
                               FontSize="12"
                               FontWeight="Bold"
                               Foreground="#333"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding MuscleGroup}"
                                   FontSize="9"
                                   Foreground="#999"/>
                        <TextBlock Text="/"
                                   FontSize="9"
                                   Foreground="#CCC"
                                   Visibility="{Binding SecondaryMuscleGroup, Converter={StaticResource StringToVisibilityConverter}}"/>
                        <TextBlock Text="{Binding SecondaryMuscleGroup}"
                                   FontSize="9"
                                   Foreground="#999"
                                   FontStyle="Italic"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="✕"
                        FontSize="10"
                        Foreground="#AAA"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="4,2"
                        Cursor="Hand"
                        ToolTip="Remove Exercise"
                        Command="{Binding RemoveExerciseCommand}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="Transparent" CornerRadius="3" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#FFEBEE"/>
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="20"/>

                <TextBlock Grid.Column="1"
                           Text="reps"
                           FontSize="9"
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           FontStyle="Italic"/>

                <TextBlock Grid.Column="2"
                           Text="weight"
                           FontSize="9"
                           Foreground="#888"
                           HorizontalAlignment="Center"
                           FontStyle="Italic"/>

                <TextBlock Grid.Column="3"
                           Text="   "
                           FontSize="9"
                           Width="20"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding Sets}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="+"
                                       FontSize="11"
                                       Foreground="#26A69A"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                            <Border Grid.Column="1" Background="White" CornerRadius="4" Margin="2,0" Padding="6,4">
                                <TextBox Text="{Binding Reps, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="11"
                                         Foreground="#333"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         ToolTip="Reps"/>
                            </Border>

                            <Border Grid.Column="2" Background="White" CornerRadius="4" Margin="2,0" Padding="6,4">
                                <TextBox Text="{Binding Weight, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontSize="11"
                                         Foreground="#333"
                                         TextAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         ToolTip="kg"/>
                            </Border>

                            <Button Grid.Column="3"
                                    Content="×"
                                    FontSize="12"
                                    Foreground="#CCC"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0"
                                    Cursor="Hand"
                                    Command="{Binding DataContext.RemoveSetCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="border" Background="Transparent" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="+ Add Set"
                    Command="{Binding AddSetCommand}"
                    FontSize="10"
                    FontWeight="SemiBold"
                    Foreground="#26A69A"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,4"
                    Cursor="Hand"
                    HorizontalAlignment="Left"
                    Margin="0,4,0,0"
                    ToolTip="Add Set">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="#E0F2F1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#B2DFDB"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
