<UserControl x:Class="ybp0.Views.WorkoutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="900">

    <UserControl.Resources>
        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#00695C"/>
            <Setter Property="Background" Value="#90FFFFFF"/>
            <Setter Property="BorderBrush" Value="#44009688"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#009688"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#22A392"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.84"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkoutComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#FDFEFE"/>
            <Setter Property="BorderBrush" Value="#A3D9CF"/>
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="Foreground" Value="#17483F"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EAF7F3" Offset="0"/>
                <GradientStop Color="#DDF3EE" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="20,20,20,12"
                Padding="28,22"
                CornerRadius="24"
                BorderBrush="#2CAFA0"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2FB3A5" Offset="0"/>
                    <GradientStop Color="#0F9C8D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Current Workout"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="{Binding SessionSubtitle}"
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="#D7F1EA"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Background="#228578"
                            CornerRadius="18"
                            Padding="18,10"
                            Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="Elapsed"
                                       FontSize="12"
                                       Foreground="#DDF4F0"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding ElapsedTime}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel VerticalAlignment="Center">
                        <Button Content="+ Add Exercise"
                                Command="{Binding OpenExerciseModalCommand}"
                                Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,8"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                        <Button Content="Stop Workout"
                                Command="{Binding StopWorkoutCommand}"
                                Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,8"
                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                        <Button Content="Finish Workout"
                                Command="{Binding FinishWorkoutCommand}"
                                Style="{StaticResource PrimaryActionButtonStyle}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FCFEFD"
                    CornerRadius="22"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.08"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="Start Options"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#17483F"/>
                    <TextBlock Text="Choose how you want to begin this session."
                               Margin="0,6,0,18"
                               Foreground="#68867F"
                               TextWrapping="Wrap"/>

                    <Border Background="#F2FAF7" CornerRadius="18" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <Border Background="#DDF2ED"
                                    CornerRadius="12"
                                    Padding="10,5"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="TODAY"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#147D70"/>
                            </Border>
                            <TextBlock Text="Today's Plan"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#17483F"/>
                            <TextBlock Text="{Binding TodayPlanSummary}"
                                       Margin="0,6,0,14"
                                       Foreground="#68867F"
                                       TextWrapping="Wrap"/>
                            <Button Content="Start Planned Workout"
                                    Command="{Binding StartPlannedWorkoutCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F7FBFA" CornerRadius="18" Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Saved Workout"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#17483F"/>
                            <TextBlock Text="Pick one of your templates and jump straight in."
                                       Margin="0,6,0,10"
                                       Foreground="#68867F"
                                       TextWrapping="Wrap"/>
                            <ComboBox ItemsSource="{Binding SavedWorkouts}"
                                      SelectedItem="{Binding SelectedSavedWorkout}"
                                      DisplayMemberPath="WorkoutName"
                                      Margin="0,0,0,12"
                                      Style="{StaticResource WorkoutComboBoxStyle}"/>
                            <Button Content="Start Saved Workout"
                                    Command="{Binding StartSavedWorkoutCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#F7FBFA" CornerRadius="18" Padding="18">
                        <StackPanel>
                            <TextBlock Text="Freestyle"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#17483F"/>
                            <TextBlock Text="Start empty and add exercises while you train."
                                       Margin="0,6,0,14"
                                       Foreground="#68867F"
                                       TextWrapping="Wrap"/>
                            <Button Content="Start Freestyle"
                                    Command="{Binding StartFreestyleWorkoutCommand}"
                                    Style="{StaticResource PrimaryActionButtonStyle}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#FCFEFD"
                    CornerRadius="22"
                    Padding="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="0" Opacity="0.08"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding SessionTitle}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#17483F"/>
                            <TextBlock Text="{Binding SessionSubtitle}"
                                       Margin="0,6,0,0"
                                       Foreground="#68867F"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#F1FAF7"
                                BorderBrush="#D3E7E1"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14,10"
                                VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Live Session"
                                           FontSize="11"
                                           FontWeight="Bold"
                                           Foreground="#15907F"/>
                                <TextBlock Text="{Binding Exercises.Count, StringFormat={}{0} exercises}"
                                           Margin="0,4,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="#17483F"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <Border Visibility="{Binding HasActiveSession, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                Background="#F4FBF8"
                                CornerRadius="18"
                                Padding="24"
                                Grid.ColumnSpan="3">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="No active workout yet."
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#17483F"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Pick an option on the left to start a session, then manage exercises and sets here."
                                           Margin="0,10,0,0"
                                           Foreground="#68867F"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Visibility="{Binding HasActiveSession, Converter={StaticResource BoolToVisibilityConverter}}"
                                      VerticalScrollBarVisibility="Auto"
                                      Grid.Column="0">
                            <ItemsControl ItemsSource="{Binding Exercises}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <local:WorkoutExerciseView DataContext="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Column="2"
                                Visibility="{Binding IsExerciseModalOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                Background="#F5FBF9"
                                CornerRadius="18"
                                BorderBrush="#CFE7E1"
                                BorderThickness="1"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border CornerRadius="18,18,0,0"
                                        Padding="18,14"
                                        BorderBrush="#BDE2D8"
                                        BorderThickness="0,0,0,1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2FB3A5" Offset="0"/>
                                            <GradientStop Color="#0F9C8D" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <TextBlock Text="Add Exercise"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="White"/>
                                        <Button Content="Close"
                                                Command="{Binding CloseExerciseModalCommand}"
                                                HorizontalAlignment="Right"
                                                Style="{StaticResource SecondaryActionButtonStyle}"/>
                                    </Grid>
                                </Border>

                                <ScrollViewer Grid.Row="1"
                                              Padding="12"
                                              VerticalScrollBarVisibility="Auto">
                                    <ListBox ItemsSource="{Binding AllExercises}"
                                             SelectedItem="{Binding SelectedExerciseToAdd}"
                                             BorderThickness="0"
                                             Background="Transparent">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="12"/>
                                                <Setter Property="Margin" Value="0,4"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="border"
                                                                    Background="#FDFEFE"
                                                                    BorderBrush="#D7ECE6"
                                                                    BorderThickness="1"
                                                                    CornerRadius="12"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <StackPanel>
                                                                        <TextBlock Text="{Binding ExerciseName}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="15"
                                                                                   Foreground="#173E37"/>
                                                                        <TextBlock Text="{Binding MuscleGroup}"
                                                                                   Margin="0,4,0,0"
                                                                                   Foreground="#68867F"/>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="1"
                                                                               Text="+"
                                                                               FontSize="24"
                                                                               Foreground="#129487"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#129487"/>
                                                                    <Setter TargetName="border" Property="Background" Value="#EEF9F6"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="border" Property="Background" Value="#E1F3EE"/>
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="#129487"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
