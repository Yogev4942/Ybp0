<UserControl x:Class="ybp0.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1200">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- Modern Button Styles -->
        <Style x:Key="ModernActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#26A69A"/>
            <Setter Property="BorderBrush" Value="#26A69A"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F5F5F5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernActionButtonStyle}">
            <Setter Property="Background" Value="#26A69A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#26A69A" BlurRadius="15" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#00897B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern Card Style -->
        <Style x:Key="ModernCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000" BlurRadius="30" ShadowDepth="4" Opacity="0.08"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Transparent Scrollbar Style -->
        <Style x:Key="TransparentScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                      Orientation="Vertical"
                                      HorizontalAlignment="Right"
                                      Maximum="{TemplateBinding ScrollableHeight}"
                                      ViewportSize="{TemplateBinding ViewportHeight}"
                                      Value="{TemplateBinding VerticalOffset}"
                                      Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                      Opacity="0.2"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8FAF9">
        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource TransparentScrollViewer}">
            <StackPanel MaxWidth="1200" HorizontalAlignment="Center" Margin="0,0,0,60">
                
                <!-- Premium Header -->
                <Border Margin="0,0,0,40" CornerRadius="0,0,50,50" ClipToBounds="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#00695C" Offset="0"/>
                            <GradientStop Color="#26A69A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="60,80,60,60">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Avatar with Ring -->
                        <Grid Grid.Column="0">
                            <Ellipse Width="170" Height="170" Stroke="White" StrokeThickness="4" Opacity="0.2"/>
                            <Border Width="160" Height="160" CornerRadius="80" Background="White" Padding="5">
                                <Border CornerRadius="75" ClipToBounds="True" Background="#EEE">
                                    <Image Source="{Binding ProfileImagePath}" Stretch="UniformToFill"/>
                                </Border>
                            </Border>
                            <Border Width="32" Height="32" Background="#4CAF50" BorderBrush="White" BorderThickness="4" CornerRadius="16"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,15,15">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2" ShadowDepth="2"/>
                                </Border.Effect>
                            </Border>
                        </Grid>

                        <!-- Identity Info -->
                        <StackPanel Grid.Column="1" Margin="50,0,0,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="{Binding FullName}" FontSize="48" FontWeight="Bold" Foreground="White">
                                    <TextBlock.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="5" Opacity="0.2" ShadowDepth="2"/>
                                    </TextBlock.Effect>
                                </TextBlock>
                                <Border Background="#33FFFFFF" CornerRadius="12" Padding="14,6" Margin="20,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding UserTypeLabel}" FontSize="13" FontWeight="Bold" Foreground="White" TextWrapping="NoWrap"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Text="{Binding Email}" FontSize="20" Foreground="#E0FFFFFF" Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding Username, StringFormat='@\{0\}'}" FontSize="18" Foreground="#B0FFFFFF" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Header Actions -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="180">
                            <Button Content="Edit Profile" 
                                    Command="{Binding EditProfileCommand}" 
                                    Style="{StaticResource ModernPrimaryButtonStyle}" 
                                    Height="45"
                                    Margin="0,0,0,15"/>
                            
                            <Button Content="Logout" 
                                    Command="{Binding LogoutCommand}" 
                                    Style="{StaticResource ModernActionButtonStyle}" 
                                    Height="45"
                                    Background="Transparent" 
                                    Foreground="White" 
                                    BorderBrush="#80FFFFFF"/>
                            
                            <!-- Request Management for Trainers -->
                            <Button Content="Incoming Requests" 
                                    Command="{Binding ToggleRequestsCommand}"
                                    Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Style="{StaticResource ModernActionButtonStyle}"
                                    Background="#20FFFFFF"
                                    Foreground="White"
                                    BorderBrush="Transparent"
                                    Margin="0,15,0,0"
                                    Height="40"
                                    FontSize="12"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Grid -->
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0">
                        <!-- About / Bio Card -->
                        <Border Style="{StaticResource ModernCardStyle}">
                            <StackPanel>
                                <TextBlock Text="📝 About Me" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,20"/>
                                <TextBlock Text="{Binding Bio, TargetNullValue='No bio provided yet.'}" 
                                           FontSize="16" Foreground="#444" 
                                           TextWrapping="Wrap" LineHeight="26" Opacity="0.9"/>
                            </StackPanel>
                        </Border>

                        <!-- Trainee Specific: Fitness Stats -->
                        <Border Style="{StaticResource ModernCardStyle}" 
                                Visibility="{Binding IsTrainee, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="💪 Physical Stats" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,25"/>
                                
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Current Weight" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding CurrentWeightDisplay}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Height" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HeightDisplay}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <Separator Background="#EEE" Margin="0,15"/>
                                <Grid>
                                    <TextBlock Text="Body Mass Index (BMI)" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <Border HorizontalAlignment="Right" Background="#E0F2F1" CornerRadius="10" Padding="15,8">
                                        <TextBlock Text="{Binding BMI}" FontSize="20" FontWeight="Bold" Foreground="#26A69A"/>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Trainer Specific: Specialization -->
                        <Border Style="{StaticResource ModernCardStyle}" 
                                Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="🎯 Specialization" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,20"/>
                                <Border Background="#E0F2F1" CornerRadius="12" Padding="20">
                                    <TextBlock Text="{Binding Specialization}" FontSize="18" FontWeight="SemiBold" Foreground="#00695C" TextAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="1">
                        <!-- Trainee Specific: Goals -->
                        <Border Style="{StaticResource ModernCardStyle}" 
                                Visibility="{Binding IsTrainee, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="🎯 Fitness Goals" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,20"/>
                                <TextBlock Text="{Binding FitnessGoal, TargetNullValue='No goals set.'}" 
                                           FontSize="16" Foreground="#444" 
                                           TextWrapping="Wrap" LineHeight="26"/>
                            </StackPanel>
                        </Border>

                        <!-- Trainer Specific: Professional Stats -->
                        <Border Style="{StaticResource ModernCardStyle}" 
                                Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="📊 Professional Stats" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,25"/>
                                
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Active Trainees" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TraineesDisplay}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Hourly Rate" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding HourlyRateDisplay}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                
                                <Separator Background="#EEE" Margin="0,15"/>
                                
                                <Grid>
                                    <TextBlock Text="Client Rating" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding AverageRating}" FontSize="24" FontWeight="Bold" Foreground="#FFA000" VerticalAlignment="Center"/>
                                        <TextBlock Text="⭐" FontSize="18" Foreground="#FFA000" VerticalAlignment="Center" Margin="5,0,0,2"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Trainer Status Card -->
                        <Border Style="{StaticResource ModernCardStyle}" 
                                Visibility="{Binding IsTrainer, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="📅 Coaching Status" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,20"/>
                                <Border Padding="20" CornerRadius="15">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAcceptingTrainees}" Value="False">
                                                    <Setter Property="Background" Value="#FFEBEE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="18" FontWeight="Bold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✅ Available for New Clients"/>
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAcceptingTrainees}" Value="False">
                                                        <Setter Property="Text" Value="⛔ Fully Booked"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- General Account Info Card -->
                        <Border Style="{StaticResource ModernCardStyle}">
                            <StackPanel>
                                <TextBlock Text="👤 Account Details" FontSize="22" FontWeight="Bold" Foreground="#00695C" Margin="0,0,0,25"/>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Gender" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Gender}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Member Type" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding UserTypeLabel}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,0,0,15">
                                    <TextBlock Text="Username" FontSize="15" Foreground="#666" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Username}" FontSize="17" FontWeight="SemiBold" Foreground="#333" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Requests Modal (Keep Original Logic, Update Styling) -->
        <Grid Visibility="{Binding IsRequestsPopupOpen, Converter={StaticResource BoolToVisibilityConverter}}" Panel.ZIndex="1000">
            <Border Background="#A0000000">
                <Border.Effect>
                    <BlurEffect Radius="20"/>
                </Border.Effect>
            </Border>
            
            <Border Width="450" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="White" CornerRadius="30" Padding="35">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="50" ShadowDepth="0" Opacity="0.3"/>
                </Border.Effect>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,25">
                        <TextBlock Text="Pending Requests" FontSize="26" FontWeight="Bold" Foreground="#00695C"/>
                        <Button Content="✕" Command="{Binding ToggleRequestsCommand}" 
                                HorizontalAlignment="Right" Background="Transparent" BorderThickness="0" 
                                Foreground="#999" FontSize="24" Cursor="Hand" Width="40" Height="40"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PendingRequests}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F9F9F9" Margin="0,0,0,12" CornerRadius="15" Padding="15">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="44" Height="44" CornerRadius="22" Background="#E0F2F1">
                                                <TextBlock Text="{Binding Username[0]}" Foreground="#26A69A" 
                                                           FontWeight="Bold" FontSize="18"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{Binding Username}" 
                                                       VerticalAlignment="Center" Margin="15,0"
                                                       FontSize="17" FontWeight="SemiBold" Foreground="#333"/>

                                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                <Button Content="✓" 
                                                        Command="{Binding DataContext.ApproveRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Background="#4CAF50" Foreground="White" Width="38" Height="38" 
                                                        BorderThickness="0" Margin="0,0,8,0" Cursor="Hand"/>
                                                <Button Content="✕" 
                                                        Command="{Binding DataContext.RejectRequestCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding}"
                                                        Background="#F44336" Foreground="White" Width="38" Height="38" 
                                                        BorderThickness="0" Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
