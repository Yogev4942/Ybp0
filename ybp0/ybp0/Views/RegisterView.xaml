<UserControl x:Class="ybp0.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Center Container -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">

            <!-- Frosted Glass Panel -->
            <Border
                Padding="30"
                CornerRadius="20"
                Width="360"
                Background="#80FFFFFF">
                <!-- 50% transparent white -->

                <Border.Effect>
                    <DropShadowEffect 
                        Color="#88A6F4FF"
                        BlurRadius="24"
                        ShadowDepth="0"
                        Opacity="0.6" />
                </Border.Effect>

                <Grid>
                    <Grid.Effect>
                        <BlurEffect Radius="12"/>
                    </Grid.Effect>

                    <StackPanel Margin="18">

                        <!-- Email -->
                        <Border CornerRadius="12"
                                Background="#F0FCFF"
                                Padding="10">
                            <TextBox 
                                BorderThickness="0"
                                Background="Transparent"
                                FontSize="15"
                                Foreground="#006070"
                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>

                        <!-- Username -->
                        <Border CornerRadius="12"
                                Background="#F1FFFA"
                                Padding="10">
                            <TextBox 
                                BorderThickness="0"
                                Background="Transparent"
                                FontSize="15"
                                Foreground="#005A66"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>

                        <!-- Password -->
                        <Border CornerRadius="12"
                                Background="#F3FEFF"
                                Padding="10">
                            <TextBlock
                                x:Name="PasswordBox"
                                FontSize="15"
                                Foreground="#005A66"
                                Background="Transparent"
                                Text="{Binding Password}"/>
                        </Border>

                        <!-- Glossy Register Button -->
                        <Button Content="Register"
                                Height="45"
                                Command="{Binding RegisterCommand}"
                                FontSize="17"
                                FontWeight="Bold"
                                Foreground="White"
                                Cursor="Hand"
                                Padding="4"
                                BorderThickness="0"
                                Margin="5">

                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#3EE0D5" Offset="0"/>
                                    <GradientStop Color="#20C4A8" Offset="1"/>
                                </LinearGradientBrush>
                            </Button.Background>

                            <Button.Effect>
                                <DropShadowEffect 
                                    Color="#40A0FFE0"
                                    BlurRadius="20"
                                    ShadowDepth="0"/>
                            </Button.Effect>

                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border CornerRadius="14"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter 
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>

                        </Button>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
