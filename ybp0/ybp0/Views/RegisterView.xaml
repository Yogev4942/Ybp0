<UserControl x:Class="ybp0.Views.RegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ybp0.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    
    <!-- Background matching main window -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#004D40" Offset="0"/>
                <GradientStop Color="#00897B" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Glassy Register Card -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Border
                Padding="40"
                CornerRadius="22"
                Width="400">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#44FFFFFF" Offset="0"/>
                        <GradientStop Color="#22FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect 
                        Color="#69F0AE"
                        BlurRadius="18"
                        ShadowDepth="0"
                        Opacity="0.5" />
                </Border.Effect>

                <StackPanel>
                    <!-- Title -->
                    <TextBlock Text="Create Account"
                              Foreground="White"
                              FontSize="26"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="Join us today"
                              Foreground="#DDFFFFFF"
                              FontSize="14"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,25"/>

                    <TextBlock Text=""
                        />

                    <!-- Email -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Email" 
                                  Foreground="#DDFFFFFF" 
                                  FontSize="13" 
                                  Margin="0,0,0,6"/>
                        <Border CornerRadius="12"
                                Background="#33FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                Padding="12">
                            <TextBox 
                                BorderThickness="0"
                                Background="Transparent"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!-- Username -->
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="Username" 
                                  Foreground="#DDFFFFFF" 
                                  FontSize="13" 
                                  Margin="0,0,0,6"/>
                        <Border CornerRadius="12"
                                Background="#33FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                Padding="12">
                            <TextBox 
                                BorderThickness="0"
                                Background="Transparent"
                                FontSize="14"
                                Foreground="White"
                                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />
                        </Border>
                    </StackPanel>

                    <!-- Password -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Password" 
                                  Foreground="#DDFFFFFF" 
                                  FontSize="13" 
                                  Margin="0,0,0,6"/>
                        <Border CornerRadius="12"
                                Background="#33FFFFFF"
                                BorderBrush="#55FFFFFF"
                                BorderThickness="1"
                                Padding="12">
                            <TextBlock
                                x:Name="PasswordBox"
                                FontSize="14"
                                Foreground="White"
                                Background="Transparent"
                                Text="{Binding Password}"/>
                        </Border>
                    </StackPanel>

                    <!-- Register Button -->
                    <Button Content="Create Account"
                            Height="48"
                            Command="{Binding RegisterCommand}"
                            FontSize="16"
                            FontWeight="Bold"
                            Cursor="Hand"
                            BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#69F0AE" Offset="0"/>
                                <GradientStop Color="#26A69A" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Foreground>White</Button.Foreground>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border"
                                       Background="{TemplateBinding Background}"
                                       CornerRadius="14">
                                    <Border.Effect>
                                        <DropShadowEffect x:Name="glow" 
                                                        Color="#69F0AE" 
                                                        BlurRadius="0" 
                                                        ShadowDepth="0" 
                                                        Opacity="0"/>
                                    </Border.Effect>
                                    <ContentPresenter 
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="glow"
                                                                   Storyboard.TargetProperty="BlurRadius"
                                                                   To="25" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="glow"
                                                                   Storyboard.TargetProperty="Opacity"
                                                                   To="0.7" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="glow"
                                                                   Storyboard.TargetProperty="BlurRadius"
                                                                   To="0" Duration="0:0:0.2"/>
                                                    <DoubleAnimation Storyboard.TargetName="glow"
                                                                   Storyboard.TargetProperty="Opacity"
                                                                   To="0" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
